<mvc:View
	controllerName="siagrob1.controller.login.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

    <Page showHeader="false" class="sapUiResponsiveContentPadding" busy="{ui>/busy}" busyIndicatorDelay="0">
    <content>
      <VBox
        fitContainer="true"
        justifyContent="Center"
        alignItems="Center"
        alignContent="Center">
        <items>
          <VBox
            fitContainer="true"
            justifyContent="Center"
            alignItems="Center"
            alignContent="Center">
            <items>
              <Image 
                class="sapUiSmallMarginBottom"
                src="https://sdk.openui5.org/1.141.0/resources/sap/ui/documentation/sdk/images/logo_sap.png"
                height="40px"
                width="80px"
              />
              <Title text="Bem vindo ao Siagro B1" level="H4" />
              <Title text="Identifique-se para utilizar o sistema" level="H5" class="sapUiSmallMarginBottom"/>
              <VBox >
                <items>
                  <Label text="Usuário:" required="true"/>
                  <Input value="{auth>/Username}" placeholder="Usuário..." width="250px" submit=".onLogin" showClearIcon="true"/>
                  <Label text="Senha:" required="true"/>
                  <Input value="{auth>/Password}" placeholder="Senha..." width="250px" submit=".onLogin" type="Password" showClearIcon="true"/>
                  <Button text="Entrar" width="250px" press=".onLogin" type="Emphasized"/>
                </items>
              </VBox>
            </items>
          </VBox>
        </items>
      </VBox>
    </content>
    <footer>
      <OverflowToolbar >
        <Text text="Desenvolvido por IDX Tecnologia" />
        <ToolbarSeparator />
        <Text text="Versão: 1.0.118" />
        <ToolbarSpacer />
        <!-- <Button icon="sap-icon://action-settings"/> -->
      </OverflowToolbar>
    </footer>
  </Page>
 
  </mvc:View>
