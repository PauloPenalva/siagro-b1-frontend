<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
  <t:Table
    id="salesContractsInvoicesTable"
    class="sapUiSizeCondensed"
    alternateRowColors="true"
    enableBusyIndicator="true"
    enableSelectAll="false"
    selectionBehavior="Row"
    selectionMode="Single"
    busyIndicatorDelay="0"
    rows="{invoicesModel>/invoices}"
    visible="true"
    >
    <t:extension>
      <OverflowToolbar>
        <content>
          <Title text="Entregas do Contrato de Venda" />
          <ToolbarSpacer />
        </content>
      </OverflowToolbar>
    </t:extension>
    <t:columns>
      <t:Column label="Filial">
        <t:template>
          <Text text="{invoicesModel>BranchName}" />
        </t:template>
      </t:Column>
      <t:Column label="Documento">
        <t:template>
          <Text text="{invoicesModel>InvoiceNumber}" />
        </t:template>
      </t:Column>
      <t:Column label="Data">
        <t:template>
          <Text text="{
            path: 'invoicesModel>InvoiceDate',
            formatter: '.formatter.formatDate'
          }" />
        </t:template>
      </t:Column>
      <t:Column label="Tipo">
        <t:template>
          <Text text="{invoicesModel>Type}" />
        </t:template>
      </t:Column>
      <t:Column label="Quantidade" hAlign="End">
        <t:template>
          <Text text="{
            path: 'invoicesModel>Quantity',
            type: 'sap.ui.model.type.Float',
            formatOptions: {
                decimals: 3,
                decimalSeparator: ',',
                groupingEnabled: true,
                groupingSeparator: '.'
            } 
          }" />   
        </t:template>
      </t:Column>
      <t:Column label="Un.Med.">
        <t:template>
          <Text text="{invoicesModel>UnitOfMeasureCode}" />
        </t:template>
      </t:Column>
      <t:Column label="Placa">
        <t:template>
          <Text text="{invoicesModel>TruckCode}" />
        </t:template>
      </t:Column>
      <t:Column label="Nota Fiscal">
        <t:template>
          <Text text="{invoicesModel>NotaFiscal}" />
        </t:template>
      </t:Column>
      <t:Column label="Qtd.Entregue" hAlign="End">
        <t:template>
          <Text text="{
            path: 'invoicesModel>DeliveredQuantity',
            type: 'sap.ui.model.type.Float',
            formatOptions: {
                decimals: 3,
                decimalSeparator: ',',
                groupingEnabled: true,
                groupingSeparator: '.'
            } 
          }" />   
        </t:template>
      </t:Column>
      <t:Column label="Qtd.Desc." hAlign="End">
        <t:template>
          <Text text="{
            path: 'invoicesModel>QuantityLoss',
            type: 'sap.ui.model.type.Float',
            formatOptions: {
                decimals: 3,
                decimalSeparator: ',',
                groupingEnabled: true,
                groupingSeparator: '.'
            } 
          }" />   
        </t:template>
      </t:Column>
      <t:Column label="Sts.Entrega">
        <t:template>
          <Text text="{invoicesModel>DeliveryStatus}" />
        </t:template>
      </t:Column>
    </t:columns>
  </t:Table>
</core:FragmentDefinition>
