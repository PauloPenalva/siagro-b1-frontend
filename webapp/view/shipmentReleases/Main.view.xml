<mvc:View
	controllerName="siagrob1.controller.shipmentReleases.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
  xmlns:f="sap.f"
  xmlns:mdc="sap.ui.mdc"
  xmlns:fb="sap.ui.comp.filterbar"
  xmlns:vm="sap.ui.fl.variants"
  xmlns:svm="sap.ui.comp.smartvariants"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">
  <f:DynamicPage busyIndicatorDelay="0" busy="{ui>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Liberações de Entrega de Contrato de Compra"/>
        </f:heading>
			</f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <f:content>
          <core:Fragment fragmentName="siagrob1.view.purchaseContracts.fragments.PurchaseContractFilterbar" type="XML" />
        </f:content>
      </f:DynamicPageHeader>
    </f:header>
		<f:content>
      <t:Table
				id="tableShipmentReleases"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
        rows="{
					path: '/ShipmentReleases',
          sorter: [
            { path: 'RowId', descending: true }
          ]
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <Title text="Liberações de Entrega" />
						<ToolbarSpacer />
						<Button type="Transparent" text="Ativar" press=".onActivate"/>
						<Button type="Transparent" text="Cancelar" press=".onCancel"/>
						<Button type="Transparent" text="Deletar" press=".onDelete"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
          <t:Column
						label="RowId"
            visible="false"
            width="10rem"
            >
						<t:template>
							<Text text="{RowId}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Status"
						sortProperty="Status"
            hAlign="Center"
            width="10rem"
						>
						<t:template>
							<ObjectStatus 
                inverted="true"
                state="{
                  path: 'Status', 
                  targetType: 'any',
                  formatter: '.formatter.stateShipmentReleaseStatus'
                }"
                text="{
                  path: 'Status', 
                  targetType: 'any',
                  formatter: '.formatter.formatShipmentReleaseStatus'
                }"/>
						</t:template>
					</t:Column>
          
          <t:Column
						label="Emissão"
						sortProperty="ReleaseDate"
            width="10rem"
						>
						<t:template>
            <Text
              wrapping="false"
              text="{
                path: 'ReleaseDate',
                targetType: 'any',
                formatter: '.formatter.formatDate'
              }"
            />
						</t:template>
					</t:Column>
          <t:Column
						label="Quantidade"
						sortProperty="ReleasedQuantity"
            hAlign="End"
            width="10rem"
						>
						<t:template>
            <ObjectNumber
              textAlign="End"
              number="{
                path: 'ReleasedQuantity',
                type: 'sap.ui.model.type.Float',
                formatOptions:{
                  decimals: 3,
                  decimalSeparator: ',',
                  groupingEnabled: true,
                  groupingSeparator: '.'
                }
              }"
              unit="{PurchaseContract/UnitOfMeasureCode}"
            />
						</t:template>
					</t:Column>
					<t:Column label="Armazem" width="30%">
						<t:template>
              <Text 
                text="({DeliveryLocationCode}) {DeliveryLocation/Name}" />
          	</t:template>
					</t:Column>
          <t:Column label="Contrato" width="30%">
						<t:template>
              <Text 
                text="({PurchaseContract/Code}) {PurchaseContract/CardName}" />
          	</t:template>
					</t:Column>
          <t:Column label="Produto" width="20%">
						<t:template>
              <Text 
                text="({PurchaseContract/ItemCode}) {PurchaseContract/ItemName}" />
          	</t:template>
					</t:Column>
				</t:columns>

			</t:Table>

    </f:content>
  
  </f:DynamicPage>

</mvc:View>
