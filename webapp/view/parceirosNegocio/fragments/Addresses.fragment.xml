<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <t:Table
      id="businessPartnerAddressesTable"
      class="sapUiSizeCondensed"
      alternateRowColors="true"
      enableBusyIndicator="true"
      enableSelectAll="false"
      selectionBehavior="Row"
      selectionMode="Single"
      busyIndicatorDelay="0"
      rows="{Addresses}"
      visible="true"
    >
    <t:extension>
      <OverflowToolbar>
        <content>
          <Title text="Endereços" />
          <ToolbarSpacer />
          <Button
            visible="{ui>/editable}"
            text="Incluir"
            type="Transparent"
            icon="sap-icon://add"
            press=".onAddAddress"
          />
          <Button
            visible="{ui>/editable}"
            text="Remover"
            type="Transparent"
            icon="sap-icon://delete"
            press=".onRemoveAddress"
          />
        </content>
      </OverflowToolbar>
    </t:extension>
    <t:columns>
      <t:Column label="Endereço">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{AddressName}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Tipo">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{AdresType}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Logradouro">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{Street}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Complemento">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{Block}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Cidade">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{City}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Estado">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{State}" 
          >
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="País">
        <t:template>
          <Input
            editable="{ui>/editable}"
            required="true"
            value="{Country}" 
          >
          </Input>
        </t:template>
      </t:Column>
    </t:columns>
  </t:Table>
</core:FragmentDefinition>
