<mvc:View
    controllerName="siagrob1.controller.App"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    height="100%"
>
    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <f:ShellBar
                id="shellBar"
                title="Siagro B1"
                secondTitle="Gestão Agrícola"
                homeIcon="https://sdk.openui5.org/1.141.0/resources/sap/ui/documentation/sdk/images/logo_sap.png"
                showNavButton="true"
                showMenuButton="true"
				        showNotifications="true"
                navButtonPressed=".onNavBack"
                homeIconPressed=".onHomePress"
                menuButtonPressed=".onMenuButtonPress"
            >
                <f:profile>
                    <Avatar initials="YK" />
                </f:profile>
            </f:ShellBar>
        </tnt:header>
        <tnt:sideContent>
            <core:Fragment fragmentName="siagrob1.fragments.SideMenu" type="XML" />
        </tnt:sideContent>
        <tnt:mainContents>
            <App id="app" />
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
