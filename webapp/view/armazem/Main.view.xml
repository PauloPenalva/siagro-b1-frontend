<mvc:View
	controllerName="siagrob1.controller.armazem.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page
		showHeader="true"
		title="Armazens"
		id="pageArmazens">
		<content>
			<t:Table
				id="tableArmazens"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/Warehouses'
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						sortProperty="Key"
						filterProperty="Key"
            width="5rem"
						>
						<t:template>
							<Text text="{Key}" wrapping="false" />
						</t:template>
					</t:Column>
					<t:Column
						label="Descrição"
						sortProperty="Name"
						filterProperty="Name"
						>
						<t:template>
							<Text text="{Name}" />
						</t:template>
					</t:Column>
          <t:Column
						label="CNPJ"
						sortProperty="TaxId"
						filterProperty="TaxId"
						>
						<t:template>
							<Text text="{TaxId}" />
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
