<core:FragmentDefinition
   	xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
   	xmlns:core="sap.ui.core">

		<t:Table
				class="sapUiSizeCondensed"
				id="tableQualidade"
				alternateRowColors="true"
				enableBusyIndicator="true"
				enableSelectAll="false"
				selectionBehavior="Row"
				selectionMode="Single"
				visibleRowCount="15"
				visibleRowCountMode="Fixed"
				busyIndicatorDelay="0"
				rows="{QualityParameters}"
				visible="true">
				<t:extension>
					<OverflowToolbar >
						<content>
							<Title text="Qualidade"/>
							<ToolbarSpacer />
							<Button text="Incluir" type="Emphasized" icon="sap-icon://add" press=".onAddQualidade" />
							<Button text="Remover" icon="sap-icon://delete" press=".onRemoveQualidade" />
						</content>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						width="10rem"
						>
						<t:template>
							<Input 
								value="{QualityAttribKey}"
								showValueHelp="true" 
								valueHelpOnly="true"
								valueHelpRequest=".cqValueHelpRequest"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Descrição"
						width="20rem"
						>
						<t:template>
							<Text 
								text="{ 
									parts: ['QualityAttribKey'], 	
									formatter: '.formatDescricaoCaracteristica'
								}"
							/>	
						</t:template>
					</t:Column>
					<t:Column
						label="Tolerancia %"
						width="10rem"
						>
						<t:template>
							<Input value="{
								path: 'MaxLimitRate',
								type: 'sap.ui.model.odata.type.Double',
								formatOptions: {
									decimals: 8,
									decimalSeparator: ',',
									groupingEnabled: true,
									groupingSeparator: '.'
								}
							}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Desconto %"
						width="10rem"
						>
						<t:template>
							<Input value="{
								path: 'ExcessDiscountRate',
								type: 'sap.ui.model.odata.type.Double',
								formatOptions: {
										decimals: 8,
										decimalSeparator: ',',
										groupingEnabled: true,
										groupingSeparator: '.'}
								}" />
						</t:template>
					</t:Column>
				</t:columns>
		</t:Table>
</core:FragmentDefinition>
