<mvc:View
	controllerName="siagrob1.controller.tabelaCusto.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page
		showHeader="true"
		title="Tabelas de Custos"
		id="TabelaCustoMain">
		<content>
			<t:Table
				id="tabelaCustoTable"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				busy="{ui>/isBusy}"
				rows="{
					path: '/TabelasCusto',
					parameters: {
						$select: 'Id,Descricao'
					}
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Search..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						sortProperty="Id"
						filterProperty="Id"
						width="10rem"
						>
						<t:template>
							<Text text="{Id}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Descrição"
						sortProperty="Descricao"
						filterProperty="Descricao"
						width="100%"
						>
						<t:template>
							<Text text="{Descricao}" wrapping="false" />
						</t:template>
					</t:Column>

				</t:columns>
			</t:Table>
		</content>
		<footer>
			<Toolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</Toolbar>
		</footer>
	</Page>

</mvc:View>
