<mvc:View
	controllerName="siagrob1.controller.branchs.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page title="Filiais">
		<content>
      <t:Table
				id="tableBranchs"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/Branchs'
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						sortProperty="Code"
						filterProperty="Code"
            visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{Code}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Nome"
						sortProperty="BranchName"
						filterProperty="BranchName"
						>
						<t:template>
							<Text text="{BranchName}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Nome Curto"
						sortProperty="ShortName"
						filterProperty="ShortName"
						>
						<t:template>
							<Text text="{ShortName}" />
						</t:template>
					</t:Column>
          <t:Column
						label="CNPJ"
						sortProperty="TaxId"
						filterProperty="TaxId"
						>
						<t:template>
							<Text text="{
                path: 'TaxId',
                formatter: '.formatter.formatCnpj'
              }" />
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
