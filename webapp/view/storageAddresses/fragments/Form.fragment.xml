<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <f:SimpleForm
      id="formLoteArmazenagem"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0"
    >
        <f:content>
            <core:Title
                text="Dados do Lote de Armazenagem"
                emphasized="true"
            />
            <Label text="Codigo"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{DocNumberKey}"
              items="{
                path: '/DocNumbers',
                parameters:{
                  $filter: 'TransactionCode eq \'StorageAddress\''
                }
              }"
              >
              <core:ListItem key="{Key}" text="{Name}"/>
              <layoutData>
                <l:GridData span="XL3 L3 M3 S8" />
              </layoutData>
            </Select>
            <Input value="{Code}" editable="false" />
             <Label text="Filial"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{BranchCode}"
              items="{
                path: '/Branchs',
                sorter: { 
                  path: 'Code'
                }
              }"
              >
              <core:ListItem key="{Code}" text="{ShortName}" additionalText="{Code}"/>
            </Select>
            <Label text="Data" />
            <DatePicker
                value="{
                  path: 'CreationDate',
                  targetType: 'any',
                  formatter: '.formatter.formatDateISO'
                }"
                editable="true"
                required="true"
                liveChange=".validateField"
                displayFormat="dd/MM/yyyy"
            />
            <Label text="Descricao" />
            <Input
                value="{Description}"
                editable="true"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Produto" />
            <Input 
								required="true"
                value="{ItemCode}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".openItemValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['ItemCode'],
                  formatter: '.formatProdutoDescricao'
                }" 
								editable="false"/>
            <Label text="Un.Med." />
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{UoM}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openUnitsOfMeasureValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['UoM'],
                formatter: '.formatUnitOfMeasureDescription'
              }" 
              editable="false"
            />
            <Label text="Cliente" />
            <Input 
								required="true"
                value="{CardCode}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".openBusinessPartnersValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['CardCode'],
                  formatter: '.formatRazaoSocialBP'
                }" 
								editable="false"/>
            
            <core:Title />
            <Label text="Armazém" />
            <Input 
								required="true"
                value="{WarehouseCode}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".openWarehouseValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['WarehouseCode'],
                  formatter: '.formatArmazemDescricao'
                }" 
								editable="false"/>
            <Label visible="true" text="Tabela de Custos" />
            <Input 
              visible="true"
              required="true"
              value="{ProcessingCostCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openProcessingCostsListValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              visible="true"
              value="{
                parts: ['ProcessingCostCode'], 
                formatter: '.formatProcessingCostDescription'
              }" 
              editable="false">
            </Input>
            <Label text="Saldo" />
            <Input
                value="{ 
                  path: 'Balance', 
                  type: 'sap.ui.model.odata.type.Double',
                    formatOptions: {
                      decimals: 0,
                      decimalSeparator: ',',
                      groupingEnabled: true,
                      groupingSeparator: '.'
                    }
                }"
                editable="false"
            />
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>
