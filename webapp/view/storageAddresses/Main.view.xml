<mvc:View
	controllerName="siagrob1.controller.storageAddresses.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page
		showHeader="true"
		title="Lotes de Armazengem"
		id="pageLotesArmazenagem">
		<content>
			<t:Table
				id="tableLoteArmazenagem"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/StorageAddresses'
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Filial"
						sortProperty="Branch/ShortName"
						filterProperty="Branch/ShortName"
            visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{Branch/ShortName}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Codigo"
						sortProperty="Code"
						filterProperty="Code"
            visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{Code}" wrapping="false"/>
						</t:template>
					</t:Column>
					<!-- <t:Column
						label="Tipo Propriedade"
						sortProperty="OwnershipType"
						filterProperty="OwnershipType"
            visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{
                path: 'OwnershipType',
                targetType: 'any'
              }" wrapping="false"/>
						</t:template>
					</t:Column> -->
					<t:Column
						label="Data"
						sortProperty="CreationDate"
						filterProperty="CreationDate"
            width="7rem"
						>
						<t:template>
							<Text
                text="{
                  path: 'CreationDate',
                  targetType: 'any',
                  formatter: '.formatter.formatDateISO'
                }"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Descrição"
						sortProperty="Description"
						filterProperty="Description"
            width="20rem"
						>
						<t:template>
							<Text text="{Description}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Produto"
						sortProperty="ItemCode"
						filterProperty="ItemCode"
            width="7rem"
						>
						<t:template>
							<Text text="{ItemCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Cliente"
            sortProperty="CardCode"
						filterProperty="CardCode"
            width="7rem"
						>
						<t:template>
							<Text text="{CardCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Saldo"
            width="10rem"
            >
						<t:template>
							<Text 
                wrapping="false"
                textAlign="Right"
                text="{
                  path: 'Balance',
                  type: 'sap.ui.model.odata.type.Double',
                    formatOptions: {
                      decimals: 3,
                      decimalSeparator: ',',
                      groupingEnabled: true,
                      groupingSeparator: '.'
                    }
                }" />
						</t:template>
					</t:Column>
       	</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
