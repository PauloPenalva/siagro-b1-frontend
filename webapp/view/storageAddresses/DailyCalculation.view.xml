<mvc:View
	controllerName="siagrob1.controller.storageAddresses.DailyCalculation"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">
  <Page title="Reprocessar Calculo Diário" >
    <f:SimpleForm
      id="storageAddressesDailyCalculationForm"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0">
        <f:content>
          <core:Title
              text="Parametros"
              emphasized="true"
          />
          <Label text="Database"/>
          <DatePicker
                value="{
                  path: 'params>/ProcessingDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                required="true"
                liveChange=".validateField"
            />
        </f:content>
        <core:Title />
        <core:Title />
    </f:SimpleForm>
    <footer>
      <OverflowToolbar >
        <ToolbarSpacer/>
        <Button text="Processar" type="Emphasized" press=".onReprocessing"/>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>
