<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <f:SimpleForm
      id="formLoteArmazenagem"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0"
    >
        <f:content>
            <core:Title
                text="Dados do Lote de Armazenagem"
                emphasized="true"
            />
            <Label text="Codigo" />
            <Input
                value="{Key}"
                editable="true"
                visible="false"
            />
            <Label text="Data" />
            <DatePicker
                value="{
                  path: 'CreationDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="true"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Descricao" />
            <Input
                value="{Description}"
                editable="true"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Produto" />
            <Input 
								required="true"
                value="{ItemCode}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".produtoValueHelpRequest">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['ItemCode'],
                  formatter: '.formatProdutoDescricao'
                }" 
								editable="false"/>
            <Label text="Cliente" />
            <Input 
								required="true"
                value="{CardCode}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".bpValueHelpRequest">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['CardCode'],
                  formatter: '.formatRazaoSocialBP'
                }" 
								editable="false"/>
            
            <core:Title />
            <Label text="Armazém" />
            <Input 
								required="true"
                value="{WarehouseKey}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".armazemValueHelpRequest">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['WarehouseKey'],
                  formatter: '.formatArmazemDescricao'
                }" 
								editable="false"/>
            <Label text="Tabela de Custos" />
            <Input 
								required="true"
                value="{ProcessingCostKey}" 
								showValueHelp="true" 
								valueHelpOnly="true" 
								valueHelpRequest=".tabelaCustoValueHelpRequest">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
								value="{
                  parts:['ProcessingCostKey'],
                  formatter: '.formatTabelaCustoDescricao'
                }" 
								editable="false"/>
            <Label text="Saldo" />
            <Input
                value="{ 
                  path: 'Balance', 
                  type: 'sap.ui.model.odata.type.Double',
                    formatOptions: {
                      decimals: 3,
                      decimalSeparator: ',',
                      groupingEnabled: true,
                      groupingSeparator: '.'
                    }
                }"
                editable="false"
            />
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>
