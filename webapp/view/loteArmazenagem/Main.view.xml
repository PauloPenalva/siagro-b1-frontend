<mvc:View
	controllerName="siagrob1.controller.loteArmazenagem.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page
		showHeader="true"
		title="Lotes de Armazengem"
		id="pageLotesArmazenagem">
		<content>
			<t:Table
				id="tableLoteArmazenagem"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/LotesArmazenagem'
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						sortProperty="Id"
						filterProperty="Id"
						>
						<t:template>
							<Text text="{Id}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Descrição"
						sortProperty="Descricao"
						filterProperty="Descricao"
						>
						<t:template>
							<Text text="{Descricao}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Produto"
						sortProperty="Produto/Descricao"
						filterProperty="Produto/Descricao"
						>
						<t:template>
							<Text text="{Produto/Descricao}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Razão Social"
            sortProperty="ParceiroNegocio/RazaoSocial"
						filterProperty="ParceiroNegocio/RazaoSocial"
						>
						<t:template>
							<Text text="{ParceiroNegocio/RazaoSocial}" wrapping="false"/>
						</t:template>
					</t:Column>
           <t:Column
						label="Nome Comercial"
            sortProperty="ParceiroNegocio/NomeFantasia"
						filterProperty="ParceiroNegocio/NomeFantasia"
						>
						<t:template>
							<Text text="{ParceiroNegocio/NomeFantasia}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="CPF/CNPJ"
            sortProperty="ParceiroNegocio/Cnpj"
						filterProperty="ParceiroNegocio/Cnpj"
						>
						<t:template>
							<Text text="{path: 'ParceiroNegocio/Cnpj', formatter: '.formatter.formatCnpj'}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Saldo"
            >
						<t:template>
							<Text 
                wrapping="false"
                textAlign="Right"
                text="{
                  path: 'Saldo',
                  type: 'sap.ui.model.odata.type.Double',
                    formatOptions: {
                      decimals: 3,
                      decimalSeparator: ',',
                      groupingEnabled: true,
                      groupingSeparator: '.'
                    }
                }" />
						</t:template>
					</t:Column>
          <t:Column
						label="Und.Med."
            >
						<t:template>
							<Text 
                wrapping="false"
                text="{UnidadeMedida}" />
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
