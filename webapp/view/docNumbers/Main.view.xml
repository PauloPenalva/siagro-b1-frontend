<mvc:View
	controllerName="siagrob1.controller.docNumbers.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page showHeader="true" title="Numeração de Documentos">
		<content>
			<t:Table
				id="docNumbersTable"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/DocNumbers'
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Key"
						sortProperty="Key"
						filterProperty="Key"
            visible="false"
            width="5rem"
						>
						<t:template>
							<Text text="{Key}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Documento"
						sortProperty="TransactionCode"
						filterProperty="CoTransactionCodede"
            visible="true"
            width="20rem"
						>
						<t:template>
							<Text text="{
                  path: 'TransactionCode',
                  targetType: 'any',
                  formatter: '.formatter.formatTransactionCode'
                }"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Nome"
						sortProperty="Name"
						filterProperty="Name"
            visible="true"
            width="20rem"
						>
						<t:template>
							<Text text="{Name}"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Primeiro Numero"
						sortProperty="FirstNumber"
						filterProperty="FirstNumber"
            visible="true"
            width="10rem"
						>
						<t:template>
							<ObjectNumber number="{FirstNumber}"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Próximo Numero"
						sortProperty="NextNumber"
						filterProperty="NextNumber"
            visible="true"
            width="10rem"
						>
						<t:template>
							<ObjectNumber number="{NextNumber}"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Prefixo"
					  visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{Prefix}"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Sufixo"
					  visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{Suffix}"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Qtd. Digitos"
					  visible="true"
            width="10rem"
						>
						<t:template>
							<Text text="{NumberSize}"/>
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
