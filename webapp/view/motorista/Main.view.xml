<mvc:View
	controllerName="siagrob1.controller.motorista.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page title="Motoristas">
		<content>
      <t:Table
				id="tableMotorista"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/TruckDrivers'
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Codigo"
						sortProperty="Key"
						filterProperty="Key"
						>
						<t:template>
							<Text text="{Key}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Nome"
						sortProperty="Name"
						filterProperty="Name"
						>
						<t:template>
							<Text text="{Name}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Cpf"
						sortProperty="Cpf"
						filterProperty="Cpf"
						>
						<t:template>
							<Text text="{
                parts: ['Cpf'],
                formatter: '.formatter.formatCnpj'
              }" />
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
