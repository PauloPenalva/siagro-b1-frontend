<mvc:View
	controllerName="siagrob1.controller.purchaseContracts.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page
		showHeader="true"
		title="Contratos de Compra"
		id="pagePurchaseContracts">
		<content>
			<t:Table
				id="tablePurchaseContracts"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/PurchaseContracts'
				}"
			>
				<t:extension>
					<OverflowToolbar >
						<ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
          <t:Column
						label="Key"
            visible="false"
						>
						<t:template>
							<Text text="{Key}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Status"
						sortProperty="Status"
						filterProperty="Status"
						>
						<t:template>
							<Text text="{path: 'Status', targetType: 'any'}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Filial"
						sortProperty="BranchCode"
						filterProperty="BranchCode"
						>
						<t:template>
							<Text text="{BranchCode}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Codigo"
						sortProperty="Code"
						filterProperty="Code"
						>
						<t:template>
							<Text text="{Code}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Sequencia"
						sortProperty="Sequence"
						filterProperty="Sequence"
						>
						<t:template>
							<Text text="{Sequence}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Complemento"
						sortProperty="Complement"
						filterProperty="Complement"
						>
						<t:template>
							<Text text="{Complement}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Emissão"
						sortProperty="CreationDate"
						filterProperty="CreationDate"
						>
						<t:template>
            <Text
              text="{
                path: 'CreationDate',
                targetType: 'any',
                formatter: '.formatter.formatDate'
              }"
            />
						</t:template>
					</t:Column>
          <t:Column
						label="Cli/For"
						sortProperty="CardCode"
						filterProperty="CardCode"
						>
						<t:template>
            <Link text="{CardCode}" endIcon="sap-icon://inspect" />
						</t:template>
					</t:Column>
          <t:Column
						label="Produto"
						sortProperty="ItemCode"
						filterProperty="ItemCode"
						>
						<t:template>
            <Link text="{ItemCode}" endIcon="sap-icon://inspect" />
						</t:template>
					</t:Column>
          <t:Column
						label="Quantidade"
						sortProperty="TotalVolume"
						filterProperty="TotalVolume"
						>
						<t:template>
            <Text
              text="{TotalVolume}"
            />
						</t:template>
					</t:Column>
					
				</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
