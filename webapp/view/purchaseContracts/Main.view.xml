<mvc:View
	controllerName="siagrob1.controller.purchaseContracts.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
  xmlns:f="sap.f"
  xmlns:mdc="sap.ui.mdc"
  xmlns:fb="sap.ui.comp.filterbar"
  xmlns:vm="sap.ui.fl.variants"
  xmlns:svm="sap.ui.comp.smartvariants"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">
  <f:DynamicPage busyIndicatorDelay="0" busy="{ui>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Contratos de Compra"/>
        </f:heading>
			</f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <f:content>
          <fb:FilterBar id="filterbar" search=".onSearch" showClearOnFB="true" clear=".onClearFilters">
            <fb:filterGroupItems>
              	<fb:FilterGroupItem name="status" label="Status" groupName="GroupStatus" visibleInFilterBar="true">
                  <fb:control>
                      <Select 
                        forceSelection="false"
                        selectedKey="{
                          path: 'filter>/Status',
                          type: 'sap.ui.model.type.String'
                        }"
                      >
                        <core:ListItem key="Draft" text="Rascunho"/>
                        <core:ListItem key="Approved" text="Aprovado"/>
                        <core:ListItem key="Finished" text="Finalizado"/>
                        <core:ListItem key="Canceled" text="Cancelado"/>
                        <core:ListItem key="InApproval" text="Em Aprovação"/>
                      </Select>
                  </fb:control>
                </fb:FilterGroupItem>
              	<fb:FilterGroupItem name="code" label="Codigo" groupName="GroupCode" visibleInFilterBar="true">
                  <fb:control>
                      <Input showClearIcon="true" value="{filter>/Code}">
                      </Input>
                  </fb:control>
                </fb:FilterGroupItem>
              	<fb:FilterGroupItem name="businessPartners" label="Fornecedor" groupName="GroupFornecedor" visibleInFilterBar="true">
                  <fb:control>
                      <Input
                        showClearIcon="true"
                        showValueHelp="true"
                        valueHelpRequest=".openBusinessPartnersValueHelp"
                        value="{filter>/CardCode}"
                        >
                      </Input>
                  </fb:control>
                </fb:FilterGroupItem>
              	<fb:FilterGroupItem name="items" label="Produto" groupName="GroupItem" visibleInFilterBar="true">
                  <fb:control>
                      <Input
                        showClearIcon="true"
                        showValueHelp="true"
                        valueHelpRequest=".openItemValueHelp"
                        value="{filter>/ItemCode}"
                        >
                      </Input>
                  </fb:control>
                </fb:FilterGroupItem>
            </fb:filterGroupItems>
          </fb:FilterBar>
        </f:content>
      </f:DynamicPageHeader>
    </f:header>
		<f:content>
      <t:Table
				id="tablePurchaseContracts"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
        rows="{
					path: '/PurchaseContracts'
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <Title text="Contratos de Compra" />
						<ToolbarSpacer />
						<Button type="Transparent" text="Copiar" press=".onCopy"/>
						<Button type="Transparent" text="Visualizar" press=".onDetail"/>
						<Button type="Transparent" text="Criar" press=".onCreate"/>
						<Button type="Transparent" text="Deletar" press=".onDelete"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
          <t:Column
						label="Key"
            visible="false"
						>
						<t:template>
							<Text text="{Key}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Tipo Doc"
						sortProperty="DocType"
						>
						<t:template>
							<Text text="{DocTypeCode}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Codigo"
						sortProperty="Code"
						>
						<t:template>
							<Text text="{Code}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Tipo de Contrato"
						sortProperty="Code"
						>
						<t:template>
							<Text text="{
                path: 'Type',
                targetType: 'any',
                formatter: '.formatter.formatContractType'
              }" />
						</t:template>
					</t:Column>
          <t:Column
						label="Complemento"
						sortProperty="Complement"
						>
						<t:template>
							<Text text="{Complement}" />
						</t:template>
					</t:Column>
          <t:Column
						label="Emissão"
						sortProperty="CreationDate"
						>
						<t:template>
            <Text
              text="{
                path: 'CreationDate',
                targetType: 'any',
                formatter: '.formatter.formatDate'
              }"
            />
						</t:template>
					</t:Column>
          <t:Column
						label="Fornecedor"
						sortProperty="CardCode"
						>
						<t:template>
            <Link text="{CardCode}" endIcon="sap-icon://inspect" />
						</t:template>
					</t:Column>
          <t:Column
						label="Produto"
						sortProperty="ItemCode"
						>
						<t:template>
            <Link text="{ItemCode}" endIcon="sap-icon://inspect" />
						</t:template>
					</t:Column>
          <t:Column
						label="Status"
						sortProperty="Status"
            hAlign="Center"
						>
						<t:template>
							<ObjectStatus 
                inverted="true"
                state="{
                  path: 'Status', 
                  targetType: 'any', 
                  formatter: '.formatter.stateContractStatus'
                }"
                text="{
                  path: 'Status', 
                  targetType: 'any', 
                  formatter: '.formatter.formatContractStatus' 
                }"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Tipo Mercado"
						sortProperty="MarketType"
						>
						<t:template>
							<Text text="{
                path: 'MarketType', 
                targetType: 'any', 
                formatter: '.formatter.formatMarketType' 
              }" />
						</t:template>
					</t:Column>
          <t:Column
						label="Quantidade"
						sortProperty="TotalVolume"
            hAlign="End"
						>
						<t:template>
            <Text
              text="{TotalVolume}"
            />
						</t:template>
					</t:Column>
					<t:Column label="Un.Med.">
						<t:template>
              <Text text="{UnitOfMeasureCode}"/>
						</t:template>
					</t:Column>
				</t:columns>

			</t:Table>

    </f:content>
  
  </f:DynamicPage>

</mvc:View>
