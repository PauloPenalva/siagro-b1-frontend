<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
>
<fb:FilterBar search=".onSearch" showClearOnFB="true" clear=".onClearFilters">
  <fb:filterGroupItems>
      <fb:FilterGroupItem name="purchaseContractBranchCode" label="Filial Ctr." groupName="GroupPurchaseContractBranchCode" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{filter>/PurchaseContractBranchCode}"
              items="{
                path: '/Branchs',
                suspended: true,
                sorter: { 
                  path: 'Code'
                }
              }">
              <core:ListItem key="{Code}" text="{ShortName}"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="purchaseContractCode" label="Contrato" groupName="GroupPurchaseContractCode" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/PurchaseContractCode}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="businessPartners" label="Fornecedor" groupName="GroupBusinessPartner" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openBusinessPartnersValueHelp"
              value="{filter>/PurchaseContractCardCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="items" label="Produto" groupName="GroupItem" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openItemValueHelp"
              value="{filter>/PurchaseContractItemCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="storageTransactionBranchCode" label="Filial Rom." groupName="GroupStorageTransactionBranchCode" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{filter>/StorageTransactionBranchCode}"
              items="{
                path: '/Branchs',
                suspended: true,
                sorter: { 
                  path: 'Code'
                }
              }">
              <core:ListItem key="{Code}" text="{ShortName}"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="storageTransactionCode" label="Romaneio" groupName="GroupStorageTransactionCode" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/StorageTransactionCode}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem> 
      
      <fb:FilterGroupItem name="dateFrom" label="Emissão de" groupName="GroupDateFrom" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/DateFrom',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="dateTo" label="Emissão até" groupName="GroupDateTo" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/DateTo',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="warehouse" label="Armazém" groupName="GroupWarehouse" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openWarehouseValueHelp"
              value="{filter>/WarehouseCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="truck" label="Veiculo" groupName="GroupTruck" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openTrucksValueHelp"
              value="{filter>/TruckCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="invoiceNumber" label="Documento" groupName="GroupInvoiceNumber" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/InvoiceNumber}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
    </fb:filterGroupItems>
  </fb:FilterBar>
</core:FragmentDefinition>
