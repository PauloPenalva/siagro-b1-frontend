<mvc:View
	controllerName="siagrob1.controller.purchaseContracts.allocation.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
  xmlns:f="sap.f"
  xmlns:mdc="sap.ui.mdc"
  xmlns:fb="sap.ui.comp.filterbar"
  xmlns:vm="sap.ui.fl.variants"
  xmlns:svm="sap.ui.comp.smartvariants"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">
  <f:DynamicPage busyIndicatorDelay="0" busy="{ui>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Entregas de Contratos de Compra"/>
        </f:heading>
			</f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <f:content>
          <core:Fragment fragmentName="siagrob1.view.purchaseContracts.fragments.PurchaseContractFilterbar" type="XML" />
        </f:content>
      </f:DynamicPageHeader>
    </f:header>
		<f:content>
      <t:Table
				id="tablePurchaseContractsAllocations"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
        rows="{
					path: '/PurchaseContractsAllocations',
          sorter: [
            { path: 'PurchaseContract/RowId' }
          ]
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <Title text="Entregas de Contratos de Compra" />
						<ToolbarSpacer />
            <Button type="Transparent" text="Exportar Excel" icon="sap-icon://excel-attachment" press=".onExcel"/>
						<Button type="Transparent" text="Estornar Entrega" press=".onDelete"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
          <t:Column
						label="Key"
            visible="false"
            width="10rem"
            >
						<t:template>
							<Text text="{Key}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Filial Ctr."
						sortProperty="PurchaseContract/BranchCode"
            width="5rem"
						>
						<t:template>
							<Text text="{PurchaseContract/BranchCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Contrato"
						sortProperty="PurchaseContract/Code"
            filterProperty="PurchaseContract/Code"
            width="10rem"
						>
						<t:template>
							<Text text="{PurchaseContract/Code}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Cod.Fornecedor"
						sortProperty="PurchaseContract/CardCode"
            width="10rem"
						>
						<t:template>
            <Text text="{PurchaseContract/CardCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Fornecedor"
						sortProperty="PurchaseContract/CardName"
            filterProperty="PurchaseContract/CardName"
            filterOperator="Contains"
            width="15rem"
						>
						<t:template>
            <Text text="{PurchaseContract/CardName}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Cod.Produto"
						sortProperty="PurchaseContract/ItemCode"
            width="10rem"
						>
						<t:template>
            <Text text="{PurchaseContract/ItemCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Produto"
						sortProperty="PurchaseContract/ItemName"
            filterProperty="PurchaseContract/ItemName"
            filterOperator="Contains"
            width="10rem"
						>
						<t:template>
            <Text text="{PurchaseContract/ItemName}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Filial Rom."
						sortProperty="StorageTransaction/BranchCode"
            width="5rem"
						>
						<t:template>
							<Text text="{StorageTransaction/BranchCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Romaneio"
						sortProperty="Code"
            width="10rem"
						>
						<t:template>
							<Text text="{StorageTransaction/Code}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Emissão"
						sortProperty="StorageTransaction/TransactionDate"
            width="10rem"
						>
						<t:template>
            <Text
              wrapping="false"
              text="{
                path: 'StorageTransaction/TransactionDate',
                targetType: 'any',
                formatter: '.formatter.formatDate'
              }"
            />
						</t:template>
					</t:Column>
          <t:Column
						label="Tipo"
						width="10rem"
						>
						<t:template>
							<Text 
                wrapping="false"
                text="{
                  path: 'StorageTransaction/TransactionType',
                  targetType: 'any',
                  formatter: '.formatter.formatStorageTransactionType'
                }"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Quantidade"
						hAlign="End"
            width="10rem"
						>
						<t:template>
            <Text
              wrapping="false"
              text="{
                path: 'Volume',
                type: 'sap.ui.model.type.Float',
                formatOptions:{
                  decimals: 3,
                  decimalSeparator: ',',
                  groupingEnabled: true,
                  groupingSeparator: '.'
                }
              }"
            />
						</t:template>
					</t:Column>
          <t:Column label="Un.Med." width="10rem">
						<t:template>
              <Text 
                text="{StorageTransaction/UnitOfMeasureCode}" 
                wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column label="Armazém" width="10rem">
						<t:template>
              <Text 
                text="{StorageTransaction/WarehouseCode}" 
                wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Placa"
						sortProperty="StorageTransaction/TruckCode"
            width="10rem"
						>
						<t:template>
							<Text text="{StorageTransaction/TruckCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Documento"
						sortProperty="StorageTransaction/InvoiceNumber"
            width="10rem"
						>
						<t:template>
							<Text text="{StorageTransaction/InvoiceNumber}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Qtd.Documento"
						width="10rem"
            hAlign="End"
						>
						<t:template>
							<Text textAlign="End" text="{StorageTransaction/InvoiceQty}" wrapping="false"/>
						</t:template>
					</t:Column>
        </t:columns>

			</t:Table>

    </f:content>
  
  </f:DynamicPage>

</mvc:View>
