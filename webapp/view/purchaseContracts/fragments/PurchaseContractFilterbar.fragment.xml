<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
>
<fb:FilterBar id="purchaseContractFb" search=".onSearch" showClearOnFB="true" clear=".onClearFilters">
  <fb:filterGroupItems>
       <fb:FilterGroupItem name="status" label="Status" groupName="GroupStatus" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/Status',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Draft" text="Rascunho"/>
              <core:ListItem key="Approved" text="Aprovado"/>
              <core:ListItem key="Finished" text="Finalizado"/>
              <core:ListItem key="Canceled" text="Cancelado"/>
              <core:ListItem key="InApproval" text="Em Aprovação"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="docType" label="Tipo do Documento" groupName="GroupDocType" visibleInFilterBar="true">
        <fb:control>
           <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openDocTypesValueHelp"
              value="{filter>/DocTypeCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="code" label="Codigo" groupName="GroupCode" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/Code}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="type" label="Tipo de Contrato" groupName="GroupType" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/Type',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Fixed" text="FIX - Preço Fixo"/>
              <core:ListItem key="ToBeDetermined" text="PAF - Preço a Fixar"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="complement" label="Complemento" groupName="GroupComplement" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/Complement}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="businessPartners" label="Fornecedor" groupName="GroupFornecedor" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openBusinessPartnersValueHelp"
              value="{filter>/CardCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="items" label="Produto" groupName="GroupItem" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openItemValueHelp"
              value="{filter>/ItemCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
     
      <fb:FilterGroupItem name="marketType" label="Tipo de Mercado" groupName="GroupMarketType" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/MarketType',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Internal" text="Interno"/>
              <core:ListItem key="External" text="Exportação"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
    </fb:filterGroupItems>
  </fb:FilterBar>
</core:FragmentDefinition>
