<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
 <f:SimpleForm
      id="formPurchaseContractsHeader"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0"
    >
        <f:content>
            <core:Title
                text="Informações Gerais"
                emphasized="true"
            />
            <Label text="Filial"/>
            <Select 
              forceSelection="false"
              required="true"
              showSecondaryValues="true"
              selectedKey="{
                path: 'BranchCode',
                targetType: 'any'
              }"
              items="{
                path: '/Branchs',
                sorter: { path: 'Code'}
              }"
              >
              <core:ListItem key="{Code}" text="{BranchName}" additionalText="{Code}"/>
            </Select>
            <core:Title />
            <Label text="Tipo Documento"/>
            <Select 
              forceSelection="false"
              required="true"
              showSecondaryValues="true"
              selectedKey="{
                path: 'DocTypeCode',
                targetType: 'any'
              }"
              items="{
                path: '/DocTypes',
                parameters: {
                  '$filter': 'TransactionCode eq \'PurchaseContract\''
                }
              }"
              >
              <core:ListItem key="{Code}" text="{Name}" additionalText="{Code}"/>
            </Select>

            <core:Title />
            
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>
