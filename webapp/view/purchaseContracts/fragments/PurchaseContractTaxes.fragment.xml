<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
  <t:Table
    id="purchaseContractsTaxesTable"
    class="sapUiSizeCondensed"
    alternateRowColors="true"
    enableBusyIndicator="true"
    enableSelectAll="false"
    selectionBehavior="Row"
    selectionMode="Single"
    busyIndicatorDelay="0"
    rows="{Taxes}"
    visible="true"
    >
    <t:extension>
      <OverflowToolbar>
        <content>
          <Title text="Impostos do Contrato de Compra" />
          <ToolbarSpacer />
          <Button
            visible="{ui>/editable}"
            text="Incluir"
            type="Transparent"
            icon="sap-icon://add"
            press=".onAddTax"
          />
          <Button
            visible="{ui>/editable}"
            text="Remover"
            type="Transparent"
            icon="sap-icon://delete"
            press=".onRemoveTax"
          />
        </content>
      </OverflowToolbar>
    </t:extension>
    <t:columns>
      <t:Column label="Codigo">
        <t:template>
          <Input
            editable="{ui>/editable}"
            width="10rem"
            required="true"
            value="{TaxCode}" 
            showValueHelp="true" 
            valueHelpOnly="true" 
            valueHelpRequest=".openTaxesValueHelp">
          </Input>
        </t:template>
      </t:Column>
      <t:Column label="Descricao">
        <t:template>
          <Text 
            width="10rem"
            text="{
              parts: ['TaxCode'],
              formatter: '.formatTaxName'
            }" 
            >
          </Text>
        </t:template>
      </t:Column>
       <t:Column label="Aliquota %">
        <t:template>
          <Text 
            width="10rem"
            text="{
              parts: ['TaxCode'],
              formatter: '.formatTaxRate'
            }" 
            >
          </Text>
        </t:template>
      </t:Column>
    </t:columns>
  </t:Table>
</core:FragmentDefinition>
