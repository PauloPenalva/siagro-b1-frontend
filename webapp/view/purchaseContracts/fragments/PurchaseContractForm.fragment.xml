<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
 <f:SimpleForm
      id="formPurchaseContracts"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0"
    >
        <f:content>
            <core:Title
                text="Dados do Contrato"
                emphasized="true"
            />
            <Label text="Codigo"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{DocNumberKey}"
              items="{
                path: '/DocNumbers',
                parameters:{
                  $filter: 'TransactionCode eq \'PurchaseContract\''
                }
              }"
              >
              <core:ListItem key="{Key}" text="{Name}"/>
              <layoutData>
                <l:GridData span="XL3 L3 M3 S8" />
              </layoutData>
            </Select>
            <Input value="{Code}" editable="false" />
            <Label text="Filial"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{BranchCode}"
              items="{
                path: '/Branchs',
                sorter: { 
                  path: 'Code'
                }
              }"
              >
              <core:ListItem key="{Code}" text="{BranchName}" additionalText="{Code}"/>
            </Select>
            <Label text="Moeda Standard"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{
                path: 'StandardCurrency',
                targetType: 'any'
              }"
              >
              <core:ListItem key="Brl" text="BRL"/>
              <core:ListItem key="Usd" text="USD"/>
            </Select>
            <Label text="Complemento" />
            <Input
              editable="{ui>/editable}"
              value="{Complement}"
              maxLength="100"
            />
            <Label text="Data" />
            <DatePicker
                value="{
                  path: 'CreationDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="{ui>/editable}"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Tipo Contrato"/>
            <Select 
              editable="false"
              forceSelection="false"
              required="true"
              selectedKey="{
                path: 'Type',
                targetType: 'any'
              }"
              >
              <core:ListItem key="Fixed" text="FIX"/>
              <core:ListItem key="ToBeDetermined" text="PAF"/>
            </Select>
            <Label text="Tipo Mercado"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{
                path: 'MarketType',
                targetType: 'any'
              }"
              >
              <core:ListItem key="Internal" text="Interno"/>
              <core:ListItem key="External" text="Exportação"/>
            </Select>
            <Label text="Comprador" />
            <Input
              editable="{ui>/editable}"
              showValueHelp="true"
              valueHelpOnly="true"
              valueHelpRequest=".openAgentsValueHelp"
              required="true"
              value="{AgentCode}"
              >
              <layoutData>
                <l:GridData span="XL3 L3 M3 S8" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts: ['AgentCode'],
                formatter: '.formatAgentName'
              }" 
              editable="false"
            />
            <Label text="Fornecedor" />
            <Input
              editable="{ui>/editable}"
              showValueHelp="true"
              valueHelpOnly="true"
              valueHelpRequest=".openBusinessPartnersValueHelp"
              required="true"
              value="{CardCode}"
              >
              <layoutData>
                <l:GridData span="XL3 L3 M3 S8" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts: ['CardCode'],
                formatter: '.formatBusinessPartnerName'
              }" 
              editable="false"
            />
            <Label text="Observações" />
            <TextArea 
              editable="{ui>/editable}"
              value="{Comments}"
              rows="5"
              cols="10"
            />

            <core:Title text="Produto e Preços" />
            <Label text="Produto" />
            <Input 
							editable="{ui>/editable}"	
              required="true"
              value="{ItemCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openItemValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['ItemCode'],
                formatter: '.formatItemName'
              }" 
              editable="false"
            />
            <Label text="Un.Med." />
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{UnitOfMeasureCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openUnitsOfMeasureValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['UnitOfMeasureCode'],
                formatter: '.formatUnitOfMeasureDescription'
              }" 
              editable="false"
            />
            <Label text="Safra" />
            <Input 
							editable="{ui>/editable}"	
              required="true"
              value="{HarvestSeasonCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openHarvestSeasonsValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['HarvestSeasonCode'],
                formatter: '.formatHarvestSeasonName'
              }" 
              editable="false"
            />
            <Label text="Quantidade"/>
            <Input 
              required="true"
              editable="{ui>/editable}"
              value="{
                path: 'TotalVolume',
                type: 'sap.ui.model.odata.type.Double',
                formatOptions: {
                    decimals: 3,
                    decimalSeparator: ',',
                    groupingEnabled: true,
                    groupingSeparator: '.'
                } 
              }"
            />
            <Label text="Preço Standard"/>
            <Input 
              required="true"
              editable="{ui>/editable}"
              value="{
                path: 'StandardPrice',
                type: 'sap.ui.model.odata.type.Double',
                formatOptions: {
                    decimals: 8,
                    decimalSeparator: ',',
                    groupingEnabled: true,
                    groupingSeparator: '.'
                } 
              }"
            />
            <Label text="Frete Standard"/>
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{
                path: 'FreightCostStandard',
                type: 'sap.ui.model.odata.type.Double',
                formatOptions: {
                    decimals: 8,
                    decimalSeparator: ',',
                    groupingEnabled: true,
                    groupingSeparator: '.'
                } 
              }"
            >
            </Input>
            <Label text="UM. Frete"/>
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{FreightUmCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openUnitsOfMeasureValueHelp"/>
            <Label text="Prev. Pagto." />
            <DatePicker
                value="{
                  path: 'StandardCashFlowDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="{ui>/editable}"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Cond.Pagamento"/>
            <TextArea 
              editable="{ui>/editable}"
              value="{PaymentTerms}"
              rows="5"
              cols="10"
            />

            <core:Title text="Entrega da Mercadoria"/>
            <Label text="Tipo do Frete"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{
                path: 'FreightTerms',
                targetType: 'any'
              }"
              >
              <core:ListItem key="Cif" text="CIF"/>
              <core:ListItem key="Fob" text="FOB"/>
              <core:ListItem key="None" text="SEM FRETE"/>
            </Select>
            <Label text="Região Logistica" />
            <Input 
							editable="{ui>/editable}"	
              required="true"
              value="{LogisticRegionCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openLogisticRegionsValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['LogisticRegionCode'],
                formatter: '.formatLogisticRegionName'
              }" 
              editable="false"
            />
            <Label text="Inicio entrega" />
            <DatePicker
                value="{
                  path: 'DeliveryStartDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="{ui>/editable}"
                required="true"
                liveChange=".validateField"
            />
            <Label text="Termino entrega" />
            <DatePicker
                value="{
                  path: 'DeliveryEndDate',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="{ui>/editable}"
                required="true"
                liveChange=".validateField"
            >
            </DatePicker>
            <Label text="Local de entrega" />
            <Input 
							editable="{ui>/editable}"	
              required="true"
              value="{DeliveryLocationCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openWarehouseValueHelp">
              <layoutData>
                  <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
            </Input>
            <Input 
              value="{
                parts:['DeliveryLocationCode'],
                formatter: '.formatWarehouseName'
              }" 
              editable="false"
            />
           
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>
