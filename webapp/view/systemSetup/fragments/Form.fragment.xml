<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <f:SimpleForm
      id="systemSetupForm"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0"
    >
        <f:content>
            <core:Title text="Dados da Configuração" emphasized="true"/>
            <Label text="Codigo" />
            <Input
              value="{Code}"
              editable="{ui>/editCode}"
              required="true"
              maxLength="4"
              liveChange=".validateField"
            />
            <Label text="Descrição" />
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{Description}"
              maxLength="200"
              liveChange=".validateField" 
            />
            <Label text="UM Padrão" />
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{DefaultUoM}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openUnitsOfMeasureValueHelp">
            </Input>
            <Label text="UM Frete Padrão" />
            <Input 
              editable="{ui>/editable}"
              required="true"
              value="{DefaultFreightUoM}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openUnitsOfMeasureValueHelp">
            </Input>
            <Label text="Moeda Padrão"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{
                path: 'DefaultCurrency',
                targetType: 'any'
              }"
              >
              <core:ListItem key="Brl" text="BRL"/>
              <core:ListItem key="Usd" text="USD"/>
            </Select>
            <Label text="Ativo ?"/>
            <CheckBox selected="{IsActive}" />
            <core:Title />
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>
