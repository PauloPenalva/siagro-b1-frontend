<mvc:View
	controllerName="siagrob1.controller.weighingTicket.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page title="Tickets de Pesagem">
		<content>
      <t:Table
				id="tableWeighTickets"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/WeighingTickets'
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <ToolbarSpacer />
						<SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Filial"
						sortProperty="BranchKey"
						filterProperty="BranchKey"
						>
						<t:template>
							<Text text="{BranchKey}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Codigo"
						sortProperty="Key"
						filterProperty="Key"
						>
						<t:template>
							<Text text="{Key}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Data"
						sortProperty="Date"
						filterProperty="Date"
						>
						<t:template>
							<Text
                text="{
                  path: 'Date',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Produto"
						sortProperty="ItemCode"
						filterProperty="ItemCode"
						>
						<t:template>
							<Text
                text="{ItemCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Cliente"
						sortProperty="CardCode"
						filterProperty="CardCode"
						>
						<t:template>
							<Text
                text="{CardCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Veiculo"
						sortProperty="TruckKey"
						filterProperty="TruckKey"
						>
						<t:template>
							<Text
                text="{TruckKey}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Motorista"
						sortProperty="TruckDriverKey"
						filterProperty="TruckDriverKey"
						>
						<t:template>
							<Text
                text="{TruckDriverKey}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="1ª Pesagem"
						sortProperty="FirstWeighValue"
						filterProperty="FirstWeighValue"
						>
						<t:template>
							<Text
                text="{FirstWeighValue}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="2ª Pesagem"
						sortProperty="SecondWeighValue"
						filterProperty="SecondWeighValue"
						>
						<t:template>
							<Text
                text="{SecondWeighValue}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Peso Bruto"
						sortProperty="GrossWeight"
						filterProperty="GrossWeight"
						>
						<t:template>
							<Text
                text="{GrossWeight}"
            />
						</t:template>
					</t:Column>
       	</t:columns>

			</t:Table>
		</content>
    <footer>
			<OverflowToolbar>
				<Button text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
				<ToolbarSpacer />
				<Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
				<Button text="Editar" icon="sap-icon://edit" press=".onEdit"/>
				<Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
			</OverflowToolbar>
		</footer>
	</Page>

</mvc:View>
