<mvc:View
	controllerName="siagrob1.controller.weighingTicket.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

	<Page title="Tickets de Pesagem" busy="{ui>/busy}" busyIndicatorDelay="0">
		<content>
      <IconTabBar 
        class="sapUiResponsiveContentPadding"
        expanded="true"
        expandable="false"
        select=".onFilterSelect">
        <items>
          <IconTabFilter
            icon="sap-icon://begin"
            iconColor="Positive"
            count="0"
            text="1ª Pesagem"
            key="FirstWeighing"
            />
          <IconTabFilter
            icon="sap-icon://begin"
            iconColor="Positive"
            count="0"
            text="2ª Pesagem"
            key="SecondWeighing" />
          <IconTabFilter
            icon="sap-icon://compare"
            iconColor="Critical"
            count="0"
            text="Classificar"
            key="QualityDetails" />
          <IconTabFilter
            icon="sap-icon://inventory"
            iconColor="Negative"
            count="0"
            text="Romaneio"
            key="WarehouseMovement" />
        </items>
      </IconTabBar>
      <t:Table
				id="tableWeighTickets"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
				rows="{
					path: '/WeighingTickets'
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <SearchField placeholder="Pesquisar..." width="30%" search=".onSearch"/>
            <ToolbarSpacer />
            <Button text="Incluir" icon="sap-icon://add" type="Emphasized" press=".onCreate"/>
            <Button text="Deletar" icon="sap-icon://delete" press=".onDelete"/>
            <MenuButton text="Outras Ações" icon="sap-icon://manager-insight">
              <menu>
                <Menu>
                  <MenuItem startsSection="true" text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
                  <MenuItem text="1ª Pesagem" icon="sap-icon://inventory" press=".openFirstWeighing"/>
                  <MenuItem text="2ª Pesagem" icon="sap-icon://inventory" press=".openSecondWeighing"/>
                  <MenuItem text="Classificar" icon="sap-icon://quality-issue" press=""/>
                  <MenuItem startsSection="true" text="Gerar Romaneio" icon="sap-icon://add-document" press=".onConfirm"/>
                </Menu>
              </menu>
            </MenuButton>
					</OverflowToolbar>
				</t:extension>
				<t:columns>
					<t:Column
						label="Filial"
						sortProperty="BrancCode"
						filterProperty="BrancCode"
            width="5rem"
						>
						<t:template>
							<Text text="{BranchCode}" />
						</t:template>
					</t:Column>
					<t:Column
						label="Codigo"
						sortProperty="Code"
						filterProperty="Code"
            width="10rem"
						>
						<t:template>
							<Text text="{Code}" wrapping="false"/>
						</t:template>
					</t:Column>
					<t:Column
						label="Operação"
						sortProperty="Type"
						filterProperty="Type"
						>
						<t:template>
							<Text text="{
                path: 'Type',
                targetType: 'any',
                formatter: '.formatter.formatOperation'
              }" />
						</t:template>
					</t:Column>
					<t:Column
						label="Data"
						sortProperty="Date"
						filterProperty="Date"
						>
						<t:template>
							<Text
                text="{
                  path: 'Date',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Produto"
						sortProperty="ItemCode"
						filterProperty="ItemCode"
						>
						<t:template>
							<Text
                text="{ItemCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Cliente"
						sortProperty="CardCode"
						filterProperty="CardCode"
						>
						<t:template>
							<Text
                text="{CardCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Veiculo"
						sortProperty="TruckCode"
						filterProperty="TruckCode"
						>
						<t:template>
							<Text
                text="{TruckCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Motorista"
						sortProperty="TruckDriverCode"
						filterProperty="TruckDriverCode"
						>
						<t:template>
							<Text
                text="{TruckDriverCode}"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="1ª Pesagem"
						sortProperty="FirstWeighValue"
						filterProperty="FirstWeighValue"
            hAlign="End"
						>
						<t:template>
							<Text
                text="{FirstWeighValue} KG"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="2ª Pesagem"
						sortProperty="SecondWeighValue"
						filterProperty="SecondWeighValue"
            hAlign="End"
						>
						<t:template>
							<Text
                text="{SecondWeighValue} KG"
            />
						</t:template>
					</t:Column>
					<t:Column
						label="Peso Bruto"
						sortProperty="GrossWeight"
						filterProperty="GrossWeight"
            hAlign="End"
						>
						<t:template>
							<Text
                text="{GrossWeight} KG"
            />
						</t:template>
					</t:Column>
       	</t:columns>

			</t:Table>
		</content>
	</Page>

</mvc:View>
