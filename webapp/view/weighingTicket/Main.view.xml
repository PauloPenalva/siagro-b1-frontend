<mvc:View
	controllerName="siagrob1.controller.weighingTicket.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
  xmlns:f="sap.f"
  xmlns:mdc="sap.ui.mdc"
  xmlns:fb="sap.ui.comp.filterbar"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

  <f:DynamicPage busyIndicatorDelay="0" busy="{ui>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Pesagem"/>
        </f:heading>
        <f:actions>
          <OverflowToolbar >
            <Button text="Incluir" icon="sap-icon://add" type="Transparent" press=".onCreate"/>
            <Button text="Deletar" icon="sap-icon://delete" type="Transparent" press=".onDelete"/>
            <MenuButton text="Outras Ações" type="Transparent" icon="sap-icon://manager-insight">
              <menu>
                <Menu>
                  <MenuItem startsSection="true" text="Atualizar" icon="sap-icon://refresh" press=".onRefresh" />
                  <MenuItem text="1ª Pesagem" icon="sap-icon://inventory" press=".openFirstWeighing"/>
                  <MenuItem text="2ª Pesagem" icon="sap-icon://inventory" press=".openSecondWeighing"/>
                  <!-- <MenuItem text="Classificar" icon="sap-icon://quality-issue" press=""/> -->
                  <MenuItem startsSection="true" text="Gerar Romaneio" icon="sap-icon://add-document" press=".onEdit"/>
                </Menu>
              </menu>
            </MenuButton>
					</OverflowToolbar>
        </f:actions>
			</f:DynamicPageTitle>
    </f:title>
		<f:content>
      <IconTabBar 
        id="weighingTicketsIconTabBar"
        expanded="true"
        expandable="false"
        select=".onFilterSelect">
        <items>
          <IconTabFilter
            icon="sap-icon://begin"
            iconColor="Negative"
            count="{
              path: '/WeighingTickets/$count',
              parameters: {
                $filter: 'Stage eq \'ReadyForFirstWeighing\''
              }
            }"
            text="1ª Pesagem"
            key="FirstWeighing"
            enabled="true"
            />
          <IconTabFilter
            icon="sap-icon://begin"
            iconColor="Critical"
            count="{
              path: '/WeighingTickets/$count',
              parameters: {
                $filter: 'Stage eq \'ReadyForSecondWeighing\''
              }
            }"
            text="2ª Pesagem"
            key="SecondWeighing" />
          <IconTabFilter
            icon="sap-icon://inventory"
            iconColor="Positive"
            count="{
              path: '/WeighingTickets/$count',
              parameters: {
                $filter: 'Stage eq \'ReadyForCompleting\''
              }
            }"
            text="Romaneio"
            key="WarehouseMovement" />
        </items>
        <content>
          <Table 
            id="tableWeighTickets"
            growing="true"
            growingThreshold="20"
            growingScrollToLoad="true"
            alternateRowColors="true"
            fixedLayout="Strict"
            busyIndicatorDelay="0"
            items="{
              path: '/WeighingTickets',
              parameters: {
                $filter: 'Stage eq \'ReadyForFirstWeighing\'',
                $count: true
              }
            }"
            >
            <headerToolbar>
              <OverflowToolbar design="Transparent">
                <Title text="Pesagens"/>
                <ToolbarSpacer/>
                <SearchField id="weighingTicketsSearch" width="30%" placeholder="Pesquisar pesagem..." search=".onSearch"/>
                <Button tooltip="Refresh" icon="sap-icon://refresh" press=".onRefresh"/>
              </OverflowToolbar>
            </headerToolbar>
            <columns>
              <Column >
                <Text text="Filial"/>
              </Column>
              <Column width="30%">
                <Text text="Codigo"/>
              </Column>
              <Column>
                <Text text="Produto"/>
              </Column>
              <Column>
                <Text text="Cliente"/>
              </Column>
              <Column>
                <Text text="1ª Pesagem"/>
              </Column>
              <Column>
                <Text text="2ª Pesagem"/>
              </Column>
              <Column>
                <Text text="Peso Bruto"/>
              </Column>
            </columns>
            <items>
              <ColumnListItem type="Navigation">
                <cells>
                  <Text text="{Branch/ShortName}"/>
                  <ObjectIdentifier title="{Code}" 
                    text="{
                      path: 'Type',
                      targetType: 'any',
                      formatter: '.formatter.formatOperation'
                    } - {
                      path: 'Date',
                      type: 'sap.ui.model.odata.type.DateTimeOffset',
                      formatOptions: {
                        pattern: 'dd/MM/yyyy'
                      }
                    } - {TruckCode}"/>
                  <Text text="{ItemCode}"/>
                  <Text text="{CardCode}"/>
                  <ObjectNumber 
                    number="{FirstWeighValue}"
                    unit="KG"
                  />
                  <ObjectNumber 
                    number="{SecondWeighValue}"
                    unit="KG"
                  />
                  <ObjectNumber 
                    number="{GrossWeight}"
                    unit="KG"
                  />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </content>
      </IconTabBar>
		</f:content>
  </f:DynamicPage>

</mvc:View>
