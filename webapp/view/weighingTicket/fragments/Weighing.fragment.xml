<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:custom="siagrob1.control"
>
  <Dialog
      id="weighingDialog"
      title="Pesagem"
      icon="sap-icon://simulate"
      contentWidth="680px"
      contentHeight="420px"
      class="sapUiSizeCompact">
      <f:SimpleForm layout="ResponsiveGridLayout" singleContainerFullSize="true">
        <f:content>
          <!-- Primeira Pesagem-->
          <Label 
            text="Peso"
            visible="{ui>/firstWeighValueVisible}" 
            />
          <Input 
            id="inputFirstWeigh" 
            visible="{ui>/firstWeighValueVisible}"
            value="{
              path: 'viewModel>/FirstWeighValue',
              type: 'sap.ui.model.odata.type.Int32'
            }" 
            textAlign="Center" />
          <Button 
            visible="{ui>/firstWeighValueVisible}"
            text="Capturar Peso" 
            icon="sap-icon://action" 
            type="Emphasized" />
          <!-- Segunda Pesagem-->
          <Label 
            text="Peso" 
            visible="{ui>/secondWeighValueVisible}"/>
          <Input 
            id="inputSecondWeigh" 
            visible="{ui>/secondWeighValueVisible}"
            value="{
              path: 'viewModel>/SecondWeighValue',
              type: 'sap.ui.model.odata.type.Int32'
            }" 
            textAlign="Center" />
          <Button 
            visible="{ui>/secondWeighValueVisible}"
            text="Capturar Peso" 
            icon="sap-icon://action" 
            type="Emphasized" />
        </f:content>
      </f:SimpleForm>
      <buttons>
        <Button text="Confirmar" type="Emphasized" visible="{ui>/firstWeighValueVisible}" press=".onSaveFirstWeighValue"/>
        <Button text="Confirmar" type="Emphasized" visible="{ui>/secondWeighValueVisible}" press=".onSaveSecondWeighValue"/>
        <Button text="Fechar" press=".onCloseDlg" />
      </buttons>
  </Dialog>
</core:FragmentDefinition>
