<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
>
<fb:FilterBar search=".onSearch" showClearOnFB="true" clear=".onClearFilters">
  <fb:filterGroupItems>
      <fb:FilterGroupItem name="branch" label="Filial" groupName="GroupBranch" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{filter>/BranchCode}"
              items="{
                path: '/Branchs',
                suspended: true,
                sorter: { 
                  path: 'Code'
                }
              }">
              <core:ListItem key="{Code}" text="{ShortName}"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="code" label="Codigo" groupName="GroupCode" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/Code}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="type" label="Operação" groupName="GroupType" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/Type',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Receipt" text="Entrada"/>
              <core:ListItem key="Shipment" text="Saída"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="dateFrom" label="Data de" groupName="GroupDateFrom" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/DateFrom',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="dateTo" label="Data até" groupName="GroupDateTo" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/DateTo',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="businessPartners" label="Cliente" groupName="GroupBusinessPartner" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openBusinessPartnersValueHelp"
              value="{filter>/CardCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="items" label="Produto" groupName="GroupItem" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openItemValueHelp"
              value="{filter>/ItemCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="truck" label="Veiculo" groupName="GroupTruck" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openTrucksValueHelp"
              value="{filter>/TruckCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="truckDriver" label="Motorista" groupName="GroupTruckDriver" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openTruckDriversValueHelp"
              value="{filter>/TruckDriverCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
    </fb:filterGroupItems>
  </fb:FilterBar>
</core:FragmentDefinition>
