<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:custom="siagrob1.control"
>
    <f:SimpleForm
      id="formCreateWeighingTicket"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0">
        <f:content>
          <core:Title
            text="Dados da Pesagem"
            emphasized="true"
          />
          <Label text="Filial" />
          <Input
            value="{BranchKey}"
            editable="true"
            required="true"
            liveChange=".validateField"
          >
          <layoutData>
            <l:GridData span="XL3 L3 M3 S4" />
          </layoutData>
          </Input>
          <Label text="Codigo" />
          <Input
            value="{Key}"
            editable="true"
            required="true"
            liveChange=".validateField"
          >
          <layoutData>
            <l:GridData span="XL3 L3 M3 S4" />
          </layoutData>
          </Input>
          <Label text="Data" />
            <DatePicker
                value="{
                  path: 'Date',
                  type: 'sap.ui.model.odata.type.DateTimeOffset',
                  formatOptions: {
                    pattern: 'dd/MM/yyyy'
                  }
                }"
                editable="true"
                required="true"
                liveChange=".validateField"
            >
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
            </DatePicker>
          <Label text="Operação" />
          <Select
              selectedKey="{Operation}"
              required="true"
              editable="true"
              forceSelection="false"
              liveChange=".validateField">
              <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
              <core:ListItem key="IN" text="ENTRADA" />
              <core:ListItem key="OUT" text="SAÍDA" />
              <core:ListItem key="NONE" text="PESAGEM" />
          </Select>
          <Label text="Veiculo" />
          <Input 
              required="true"
              value="{TruckKey}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".truckValueHelpRequest">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Label text="Motorista" />
          <Input 
              required="true"
              value="{TruckDriverKey}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".truckDriverValueHelpRequest">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['TruckDriverKey'], 
                formatter: '.formatTruckDriverName'
              }" 
              editable="false">
          </Input>
          <Label text="Cliente" />
          <Input 
              required="true"
              value="{CardCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".costumerValueHelpRequest">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['CardCode'], 
                formatter: '.formatCustomerName'
              }" 
              editable="false">
          </Input>
          <Label text="Produto" />
          <Input 
              required="true"
              value="{ItemCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".itemValueHelpRequest">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['ItemCode'], 
                formatter: '.formatItemName'
              }" 
              editable="false">
          </Input>
        </f:content>
        <core:Title />
        <core:Title />
    </f:SimpleForm>
</core:FragmentDefinition>
