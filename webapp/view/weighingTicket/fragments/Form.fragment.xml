<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:custom="siagrob1.control"
>
    <f:SimpleForm
      id="formCreateWeighingTicket"
      editable="true"
      layout="ResponsiveGridLayout"
      labelSpanXL="4"
      labelSpanL="4"
      labelSpanM="4"
      labelSpanS="12"
      adjustLabelSpan="false"
      emptySpanXL="0"
      emptySpanL="0"
      emptySpanM="0"
      emptySpanS="0"
      columnsXL="3"
      columnsL="2"
      columnsM="2"
      singleContainerFullSize="true"
		  busyIndicatorDelay="0">
        <f:content>
          <core:Title
            text="Dados da Pesagem"
            emphasized="true"
          />
          <Label text="Codigo"/>
          <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{DocNumberKey}"
              items="{
                path: '/DocNumbers',
                parameters:{
                  $filter: 'TransactionCode eq \'WeighingTicket\''
                }
              }"
              >
              <core:ListItem key="{Key}" text="{Name}"/>
              <layoutData>
                <l:GridData span="XL3 L3 M3 S8" />
              </layoutData>
            </Select>
            <Input value="{Code}" editable="false" />
            <Label text="Filial"/>
            <Select 
              editable="{ui>/editable}"
              forceSelection="false"
              required="true"
              selectedKey="{BranchCode}"
              items="{
                path: '/Branchs',
                sorter: { 
                  path: 'Code'
                }
              }"
              >
              <core:ListItem key="{Code}" text="{ShortName}" additionalText="{Code}"/>
            </Select>
          <Label text="Data" />
          <DatePicker
              value="{
                path: 'Date',
                type: 'sap.ui.model.odata.type.DateTimeOffset',
                formatOptions: {
                  pattern: 'dd/MM/yyyy'
                }
              }"
              editable="{ui>/editable}"
              required="true"
              liveChange=".validateField"
          >
          <layoutData>
              <l:GridData span="XL3 L3 M3 S4" />
          </layoutData>
          </DatePicker>
          <Label text="Operação" />
          <Select
              selectedKey="{
                path: 'Type',
                targetType: 'any'
              }"
              required="true"
              editable="{ui>/editable}"
              forceSelection="false">
              <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
              </layoutData>
              <core:ListItem key="Receipt" text="Entrada" />
              <core:ListItem key="Shipment" text="Saída" />
              <!-- <core:ListItem key="None" text="Pesagem" /> -->
          </Select>
          <Label text="Veiculo" />
          <Input 
              required="true"
              editable="{ui>/editable}"
              value="{TruckCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openTrucksValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Label text="Motorista" />
          <Input 
              required="true"
              editable="{ui>/editable}"
              value="{TruckDriverCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openTruckDriversValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['TruckDriverCode'], 
                formatter: '.formatTruckDriverName'
              }" 
              editable="false">
          </Input>
          <Label text="Cliente" />
          <Input 
              required="true"
              editable="{ui>/editable}"
              value="{CardCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openCostumersValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['CardCode'], 
                formatter: '.formatCustomerName'
              }" 
              editable="false">
          </Input>
          <Label text="Produto" />
          <Input 
              required="true"
              editable="{ui>/editable}"
              value="{ItemCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openItemValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              value="{
                parts: ['ItemCode'], 
                formatter: '.formatItemName'
              }" 
              editable="false">
          </Input>

          <core:Title />
          <Label visible="{ui>/visible}" text="Primeira Pesagem" />
          <Input 
            description="KG"
            visible="{ui>/visible}"
            editable="false"
            value="{
              path: 'FirstWeighValue',
              type: 'sap.ui.model.type.Integer',
              formatOptions: {
                groupingEnabled: true,
                groupingSeparator: '.'
              } 
            }" />
          <Label visible="{ui>/visible}" text="Segunda Pesagem" />
          <Input 
            description="KG"
            visible="{ui>/visible}"
            editable="false"
            value="{
              path: 'SecondWeighValue',
              type: 'sap.ui.model.type.Integer',
              formatOptions: {
                groupingEnabled: true,
                groupingSeparator: '.'
              } 
            }" />
          <Label visible="{ui>/visible}" text="Peso Bruto" />
          <Input 
            visible="{ui>/visible}"
            editable="false"
            description="KG"
            value="{
              path: 'GrossWeight',
              type: 'sap.ui.model.type.Integer',
              formatOptions: {
                groupingEnabled: true,
                groupingSeparator: '.'
              } 
            }" />
          <Label visible="{ui>/visible}" text="Tabela de Custos" />
          <Input 
              visible="{ui>/visible}"
              required="{ui>/required}"
              editable="{ui>/editableProcessingCost}"
              value="{ProcessingCostCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openProcessingCostsListValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              visible="{ui>/visible}"
              value="{
                parts: ['ProcessingCostCode'], 
                formatter: '.formatProcessingCostDescription'
              }" 
              editable="false">
          </Input>
          <Label visible="{ui>/visible}" text="Lote de Armazenagem" />
          <Input 
              visible="{ui>/visible}"
              required="{ui>/required}"
              editable="{ui>/editableStorageAddress}"
              value="{StorageAddressCode}" 
              showValueHelp="true" 
              valueHelpOnly="true" 
              valueHelpRequest=".openStorageAddressesValueHelp">
            <layoutData>
                <l:GridData span="XL3 L3 M3 S4" />
            </layoutData>
          </Input>
          <Input 
              visible="{ui>/visible}"
              value="{
                parts: ['StorageAddressCode'], 
                formatter: '.formatStorageAddressDescription'
              }" 
              editable="false">
          </Input>
         
          <Label visible="{ui>/visible}" text="Observações"/>
          <TextArea 
            visible="{ui>/visible}"
            editable="{ui>/editableComments}"
            value="{Comments}"
            rows="5"
            cols="20"
          />

        </f:content>
        <core:Title />
    </f:SimpleForm>
</core:FragmentDefinition>
