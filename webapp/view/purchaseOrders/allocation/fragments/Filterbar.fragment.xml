<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
>
<fb:FilterBar search=".onSearch" showClearOnFB="true" clear=".onClearFilters">
  <fb:filterGroupItems>
      <fb:FilterGroupItem name="branchCode" label="Filial" groupName="GroupBranchCode" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{filter>/BranchCode}"
              items="{
                path: '/Branchs',
                suspended: true,
                sorter: { 
                  path: 'Code'
                }
              }">
              <core:ListItem key="{Code}" text="{ShortName}"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="transactionStatus" label="Status" groupName="GroupTransactionStatus" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/TransactionStatus',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Pending" text="Pendente"/>
              <core:ListItem key="Confirmed" text="Confirmado"/>
              <core:ListItem key="Cancelled" text="Cancelado"/>
              <core:ListItem key="Invoiced" text="Faturado"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="code" label="Codigo" groupName="GroupCode" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/Code}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="type" label="Tipo" groupName="GroupType" visibleInFilterBar="true">
        <fb:control>
            <Select 
              forceSelection="false"
              selectedKey="{
                path: 'filter>/TransactionType',
                type: 'sap.ui.model.type.String'
              }"
            >
              <core:ListItem key="Receipt" text="Entrada"/>
              <core:ListItem key="Shipment" text="Saída"/>
              <core:ListItem key="QualityLoss" text="Quebra Técnica"/>
              <core:ListItem key="SalesShipment" text="Venda"/>
              <core:ListItem key="SalesShipmentReturn" text="Dev.Venda"/>
              <core:ListItem key="Purchase" text="Compra"/>
              <core:ListItem key="PurchaseReturn" text="Dev.Compra"/>
              <core:ListItem key="PurchaseQtyComplement" text="Compl.Qtd."/>
              <core:ListItem key="PurchasePriceComplement" text="Compl.Preço"/>
            </Select>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="transactionDateFrom" label="Emissão de" groupName="GroupTransactionDateFrom" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/TransactionDateFrom',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="transactionDateTo" label="Emissão até" groupName="GroupTransactionDateTo" visibleInFilterBar="true">
        <fb:control>
           <DatePicker 
            value="{
              path: 'filter>/TransactionDateTo',
              type: 'sap.ui.model.type.String'
            }"
            displayFormat="dd/MM/yyyy"
            valueFormat="yyyy-MM-dd"
           />
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="truck" label="Veiculo" groupName="GroupTruck" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openTrucksValueHelp"
              value="{filter>/TruckCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="invoiceNumber" label="Documento" groupName="GroupInvoiceNumber" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/InvoiceNumber}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
       <fb:FilterGroupItem name="warehouse" label="Armazém" groupName="GroupWarehouse" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openWarehouseValueHelp"
              value="{filter>/WarehouseCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="businessPartners" label="Cli/For" groupName="GroupBusinessPartner" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openBusinessPartnersValueHelp"
              value="{filter>/CardCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="items" label="Produto" groupName="GroupItem" visibleInFilterBar="true">
        <fb:control>
            <Input
              showClearIcon="true"
              showValueHelp="true"
              valueHelpRequest=".openItemValueHelp"
              value="{filter>/ItemCode}"
              >
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
      <fb:FilterGroupItem name="chaveNFe" label="Chave NFe" groupName="GroupChaveNFe" visibleInFilterBar="true">
        <fb:control>
            <Input showClearIcon="true" value="{filter>/ChaveNFe}">
            </Input>
        </fb:control>
      </fb:FilterGroupItem>
    </fb:filterGroupItems>
  </fb:FilterBar>
</core:FragmentDefinition>
