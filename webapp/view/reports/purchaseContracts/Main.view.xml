<mvc:View
	controllerName="siagrob1.controller.reports.purchaseContracts.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">

  <ScrollContainer
    height="100%"
    width="100%"
    horizontal="true"
    vertical="true">
    <FlexBox direction="Column" renderType="Div" class="sapUiSmallMargin">
      <PDFViewer showDownloadButton="false" source="{viewModel>/Source}" isTrustedSource="true" title="{viewModel>/Title}" height="{viewModel>/Height}">
        <layoutData>
          <FlexItemData growFactor="1" />
        </layoutData>
      </PDFViewer>
    </FlexBox>
  </ScrollContainer>
  
</mvc:View>
