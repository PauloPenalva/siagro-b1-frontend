<mvc:View
    controllerName="siagrob1.controller.shippingTransaction.SelectShipmentRelease"
    displayBlock="true"
    height="100%"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:uxap="sap.uxap"
    core:require="{
      formatter: 'siagrob1/model/formatter'
    }">
    <uxap:ObjectPageLayout
        showFooter="true"
        toggleHeaderOnTitleClick="true"
        preserveHeaderStateOnScroll="false"
        busy="{ui>/busy}"
        busyIndicatorDelay="0"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
              <uxap:breadcrumbs>
                <Breadcrumbs separatorStyle="GreaterThan" currentLocationText="Seleção de Contrato">
                  <Link text="Expedição de Grãos" press=".onCancel" />
                </Breadcrumbs>
              </uxap:breadcrumbs>
              <uxap:expandedHeading>
                  <Title text="Expedição de Grãos" />
              </uxap:expandedHeading>
              <uxap:snappedHeading>
                  <Title text="Expedição de Grãos" />
              </uxap:snappedHeading>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
        <uxap:sections>
            <uxap:ObjectPageSection
                titleUppercase="false"
                title="Selecionar Contrato de Compra"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                           <ScrollContainer
                            width="100%"
                            horizontal="true"
                            vertical="false">
                           <Table
                              id="tableSelectShipmentRelease"
                              class="sapUiSizeCondensed"
                              alternateRowColors="true"
                              inset="false"
                              
                              mode="SingleSelect"
                               items="{
                                  path: 'contracts>/'
                                }"
                             >
                              <headerToolbar>
                                  <OverflowToolbar>
                                      <content>
                                          <Title
                                              text="Contratos"
                                              level="H2"
                                          />
                                          <ToolbarSpacer />
                                      </content>
                                  </OverflowToolbar>
                              </headerToolbar>
                              <columns>
                                  <Column visible="false" width="3rem">
                                    <Text text="Key" />
                                  </Column>
                                  <Column width="3rem">
                                    <Text />
                                  </Column>
                                  <Column width="10rem">
                                      <Text text="Filial" wrapping="false"/>
                                  </Column>
                                  <Column width="8rem">
                                      <Text text="Contrato" wrapping="false"/>
                                  </Column>
                                  <Column width="3rem">
                                      <Text text="Item" wrapping="false"/>
                                  </Column>
                                  <Column width="25rem">
                                      <Text text="Fornecedor" wrapping="false"/>
                                  </Column>
                                  <Column width="10rem">
                                      <Text text="CNPJ" wrapping="false"/>
                                  </Column>
                                  <Column width="10rem">
                                      <Text text="Municipio" wrapping="false"/>
                                  </Column>
                                  <Column width="3rem">
                                      <Text text="Uf" wrapping="false"/>
                                  </Column>
                                  <Column width="6rem">
                                      <Text text="Armazem" wrapping="false"/>
                                  </Column>
                                  <Column visible="false" width="3rem">
                                      <Text text="Cod.Prodto" />
                                  </Column>
                                  <Column width="8rem">
                                      <Text text="Produto" wrapping="false" />
                                  </Column>
                                  <Column hAlign="End" width="10rem">
                                      <Text text="Saldo" />
                                  </Column>
                              </columns>
                              <items>
                                  <ColumnListItem>
                                      <cells>
                                          <Text text="{contracts>ShipmentReleaseKey}" wrapping="false"/>
                                          <core:Icon tooltip="{contracts>Notes}" src="sap-icon://information" />
                                          <Text text="{contracts>BranchShortName}" wrapping="false"/>
                                          <ObjectIdentifier title="{contracts>PurchaseContractCode}" />
                                          <Text text="{contracts>RowId}" wrapping="false"/>
                                          <Text text="{contracts>FName}" wrapping="false"/>
                                          <Text text="{contracts>TaxId}" wrapping="false"/>
                                          <Text text="{contracts>City}" wrapping="false"/>
                                          <Text text="{contracts>State}" wrapping="false"/>
                                          <Text text="{contracts>DeliveryLocationCode}" wrapping="false"/>
                                          <Text text="{contracts>ItemCode}" wrapping="false"/>
                                          <Text text="{contracts>ItemName}" wrapping="false"/>
                                          <ObjectNumber
                                              number="{
                                                path: 'contracts>AvailableQuantity',
                                                type: 'sap.ui.model.type.Float',
                                                formatOptions: {
                                                    decimals: 3,
                                                    decimalSeparator: ',',
                                                    groupingEnabled: true,
                                                    groupingSeparator: '.'
                                                  }
                                              }"
                                              unit="{contracts>UnitOfMeasureCode}"
                                          />
                                      </cells>
                                  </ColumnListItem>
                              </items>
                          </Table>
                          </ScrollContainer>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
        <uxap:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Voltar"
                    press=".onCancel"
                />
               <Button
                    text="Incluir Expedicao"
                    icon="sap-icon://add"
                    press=".onCreateShippingTransaction"
                    type="Emphasized"
                />
            </OverflowToolbar>
        </uxap:footer>
    </uxap:ObjectPageLayout>
   
</mvc:View>
