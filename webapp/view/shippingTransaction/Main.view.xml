<mvc:View
    controllerName="siagrob1.controller.shippingTransaction.Main"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:mdc="sap.ui.mdc"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:vm="sap.ui.fl.variants"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:uxap="sap.uxap"
    core:require="{
    formatter: 'siagrob1/model/formatter'
  }"
>
    <uxap:ObjectPageLayout
        showFooter="true"
        toggleHeaderOnTitleClick="true"
        preserveHeaderStateOnScroll="false"
        busy="{ui>/busy}"
        busyIndicatorDelay="0"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
              <uxap:breadcrumbs>
                <Breadcrumbs separatorStyle="GreaterThan" currentLocationText="Expedição de Grãos"/>
              </uxap:breadcrumbs>
              <uxap:expandedHeading>
                  <Title text="Expedição de Grãos" />
              </uxap:expandedHeading>
              <uxap:snappedHeading>
                  <Title text="Expedição de Grãos" />
              </uxap:snappedHeading>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
        <uxap:headerContent>
            <fb:FilterBar
                search="onSearch"
                showRestoreButton="false"
                filterBarExpanded="true"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="items"
                        label="Produto"
                        groupName="GroupItem"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <Input
                                showClearIcon="true"
                                showValueHelp="true"
                                valueHelpRequest=".openItemValueHelp"
                                value="{filter>/ItemCode}"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
        </uxap:headerContent>
        <uxap:sections>
            <uxap:ObjectPageSection
                titleUppercase="false"
                title="Seleção de Armazém"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table
                                id="tableShipmentReleasesBalance"
                                class="sapUiSizeCondensed"
                                alternateRowColors="true"
                                inset="false"
                                items="{
                                  path: 'balance>/'
                                }"
                                mode="SingleSelect"
                            >
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <content>
                                            <Title
                                                text="Seleção de Armazém para Expedição"
                                                level="H2"
                                            />
                                            <ToolbarSpacer />
                                            <SearchField
                                                placeholder="Pesquisar..."
                                                width="30%"
                                                search=".onFilter"
                                            />
                                        </content>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="3rem">
                                        <Text />
                                    </Column>
                                    <Column width="20rem">
                                        <Text text="Armazem" />
                                    </Column>
                                    <Column width="20rem">
                                        <Text text="Nome Fantasia" />
                                    </Column>
                                    <Column>
                                        <Text text="Codigo" />
                                    </Column>
                                    <Column>
                                        <Text text="CNPJ" />
                                    </Column>
                                    <Column>
                                        <Text text="Municipio" />
                                    </Column>
                                    <Column>
                                        <Text text="Estado" />
                                    </Column>
                                    <Column>
                                        <Text
                                            text="Cod.Variedade"
                                            visible="false"
                                        />
                                    </Column>
                                    <!-- <Column>
                                        <Text text="Variedade" />
                                    </Column> -->
                                    <Column hAlign="End">
                                        <Text text="Saldo" />
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <core:Icon tooltip="{balance>Notes}" src="sap-icon://information" />
                                            <ObjectIdentifier
                                                title="{balance>DeliveryLocationName}"
                                            />
                                            <Text
                                                text="{balance>FName}"
                                            />
                                            <Text
                                                text="{balance>DeliveryLocationCode}"
                                            />
                                             <Text
                                                text="{balance>TaxId}"
                                            />
                                            <Text text="{balance>City}" />
                                            <Text text="{balance>State}" />
                                            <Text
                                                text="{balance>codigoVariedade}"
                                                visible="false"
                                            />
                                            <!-- <Text
                                                text="{balance>descricaoVariedade}"
                                            /> -->
                                            <ObjectNumber
                                                number="{
                                                  path: 'balance>AvailableQuantity',
                                                  type: 'sap.ui.model.type.Float',
                                                  formatOptions: {
                                                    decimals: 3,
                                                    decimalSeparator: ',',
                                                    groupingEnabled: true,
                                                    groupingSeparator: '.'
                                                  }
                                                }"
                                                unit="{balance>UnitOfMeasureCode}"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
        <uxap:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Selecionar Contrato"
                    icon="sap-icon://add"
                    press=".selectShipmentRelease"
                    type="Emphasized"
                />
            </OverflowToolbar>
        </uxap:footer>
    </uxap:ObjectPageLayout>
</mvc:View>
