<mvc:View
	controllerName="siagrob1.controller.ownershipTransfers.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
  xmlns:f="sap.f"
  xmlns:mdc="sap.ui.mdc"
  xmlns:fb="sap.ui.comp.filterbar"
  xmlns:vm="sap.ui.fl.variants"
  xmlns:svm="sap.ui.comp.smartvariants"
	core:require="{
		formatter: 'siagrob1/model/formatter'
	}">
  <f:DynamicPage busyIndicatorDelay="0" busy="{ui>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Transferencias de propriedade"/>
        </f:heading>
			</f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <f:content>
          <core:Fragment fragmentName="siagrob1.view.ownershipTransfers.fragments.Filterbar" type="XML" />
        </f:content>
      </f:DynamicPageHeader>
    </f:header>
		<f:content>
      <t:Table
				id="ownershipTransfersTable"
				busyIndicatorDelay="0"
				selectionMode="Single"
				selectionBehavior="Row"
				class="sapUiSizeCondensed"
				visibleRowCountMode="Auto"
				enableBusyIndicator="true"
				alternateRowColors="true"
        rows="{
					path: '/OwnershipTransfers',
          sorter: [
            { path: 'RowId', descending: true }
          ]
				}"
			>
				<t:extension>
					<OverflowToolbar >
            <Title text="Transferencias de propriedade" />
						<ToolbarSpacer />
            <Button type="Transparent" text="Exportar Excel" icon="sap-icon://excel-attachment" press=".onExcel"/>
						<Button type="Transparent" text="Copiar" press=".onCopy"/>
						<Button type="Transparent" text="Visualizar" press=".onDetail"/>
						<Button type="Transparent" text="Criar" press=".onCreate"/>
						<!-- <Button type="Transparent" text="Deletar" press=".onDelete"/> -->
					</OverflowToolbar>
				</t:extension>
				<t:columns>
          <t:Column
						label="Key"
            visible="false"
            width="10rem"
            >
						<t:template>
							<Text text="{Key}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Filial"
						sortProperty="Branch/ShortName"
            width="5rem"
						>
						<t:template>
							<Text text="{Branch/ShortName}" wrapping="false"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Status"
						sortProperty="TransferStatus"
            hAlign="Center"
            width="10rem"
						>
						<t:template>
							<ObjectStatus 
                inverted="true"
                state="{
                  path: 'TransferStatus', 
                  targetType: 'any', 
                  formatter: '.formatter.stateStorageTransactionStatus'
                }"
                text="{
                  path: 'TransferStatus', 
                  targetType: 'any', 
                  formatter: '.formatter.formatStorageTransactionStatus' 
                }"/>
						</t:template>
					</t:Column>
          <t:Column
						label="Codigo"
						sortProperty="Code"
            width="10rem"
						>
						<t:template>
							<Text text="{TransferCode}" wrapping="false"/>
						</t:template>
					</t:Column>
          
          <t:Column
						label="Emissão"
						sortProperty="Date"
            width="10rem"
						>
						<t:template>
            <Text
              wrapping="false"
              text="{
                path: 'Date',
                targetType: 'any',
                formatter: '.formatter.formatDate'
              }"
            />
						</t:template>
					</t:Column>
          <t:Column
						label="Quantidade"
						sortProperty="Quantity"
            hAlign="End"
            width="10rem"
						>
						<t:template>
            <ObjectNumber
              textAlign="End"
              number="{
                path: 'Quantity',
                type: 'sap.ui.model.type.Float',
                formatOptions:{
                  decimals: 3,
                  decimalSeparator: ',',
                  groupingEnabled: true,
                  groupingSeparator: '.'
                }
              }"
              unit="{UomCode}"
            />
						</t:template>
					</t:Column>
       	</t:columns>

			</t:Table>

    </f:content>
  
  </f:DynamicPage>

</mvc:View>
