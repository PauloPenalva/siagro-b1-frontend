{
	"_version": "1.21.0",

	"sap.app": {
		"id": "siagrob1",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "${version}"
		},
		"sourceTemplate": {
			"id": "generator-ui5-ts-app",
			"version": "1.1.0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/",
				"type": "OData",
				"settings": {
				"odataVersion": "4.0"
				}
			}
		}
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},

	"sap.ui5": {
		"rootView": {
			"viewName": "siagrob1.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.141.0",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "siagrob1.i18n.i18n",
					"supportedLocales": ["en", "de"],
					"fallbackLocale": "en",
					"async": true
				}
			},
			"": {
				"type": "sap.ui.model.odata.v4.ODataModel",
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"synchronizationMode": "None",
					"autoExpandSelect": true,
					"earlyRequests": false,
					"updateGroupId" : "UpdateGroup",
					"groupId": "$auto",
								"httpHeaders": {

					}
				}
			},
			"ui": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {}
			}
		},

		"routing": {
			"config": {
				"bypassed": {
					"target": "notFound"
				},
				"routerClass": "sap.m.routing.Router",
				"type": "View",
				"viewType": "XML",
				"controlId": "app",
				"controlAggregation": "pages"
			},
			"routes": [
				{
					"pattern": "",
					"name": "main",
					"target": "main"
				},
				{
					"pattern": "parceirosNegocio",
					"name": "parceirosNegocio",
					"target": "parceirosNegocio"
				},
				{
					"pattern": "produtos",
					"name": "produtos",
					"target": "produtos"
				},
				{
					"pattern": "tabelaCusto",
					"name": "tabelaCusto",
					"target": "tabelaCusto"
				},
				{
					"pattern": "tabelaCustoNew",
					"name": "tabelaCustoNew",
					"target": "tabelaCustoNew"
				},
				{
					"pattern": "tabelaCustoEdit/{id}",
					"name": "tabelaCustoEdit",
					"target": "tabelaCustoEdit"
				},
        {
          "pattern": "armazens",
          "name": "armazens",
          "target": "armazens"
        },
        {
          "pattern": "armazensNew",
          "name": "armazensNew",
          "target": "armazensNew"
        },
        {
          "pattern": "armazensEdit/{id}",
          "name": "armazensEdit",
          "target": "armazensEdit"
        },
        {
          "pattern": "lotesArmazenagem",
          "name": "lotesArmazenagem",
          "target": "lotesArmazenagem"
        },
        {
          "pattern": "lotesArmazenagemNew",
          "name": "lotesArmazenagemNew",
          "target": "lotesArmazenagemNew"
        },
        {
          "pattern": "lotesArmazenagemEdit/{id}",
          "name": "lotesArmazenagemEdit",
          "target": "lotesArmazenagemEdit"
        },
        {
          "pattern": "safras",
          "name": "safras",
          "target": "safras"
        },
        {
          "pattern": "safrasNew",
          "name": "safrasNew",
          "target": "safrasNew"
        },
        {
          "pattern": "safrasEdit/{id}",
          "name": "safrasEdit",
          "target": "safrasEdit"
        }, 
        {
          "pattern": "motoristas",
          "name": "motoristas",
          "target": "motoristas"
        },
        {
          "pattern": "motoristasNew",
          "name": "motoristasNew",
          "target": "motoristasNew"
        },
        {
          "pattern": "motoristasEdit/{id}",
          "name": "motoristasEdit",
          "target": "motoristasEdit"
        },
        {
          "pattern": "veiculos",
          "name": "veiculos",
          "target": "veiculos"
        },
        {
          "pattern": "veiculosNew",
          "name": "veiculosNew",
          "target": "veiculosNew"
        },
        {
          "pattern": "veiculosEdit/{id}",
          "name": "veiculosEdit",
          "target": "veiculosEdit"
        }
			],
			"targets": {
				"notFound" : {
					"id" : "notFound",
					"name" : "siagrob1.view.NotFound",
					"transition" : "show"
				},
				"main": {
					"id": "main",
					"name": "siagrob1.view.Main"
				},
				"parceirosNegocio": {
					"id": "ParceirosNegocio",
          "level": 2,
					"name": "siagrob1.view.parceirosNegocio.Main"
				},
				"produtos": {
					"id": "produtos",
          "level": 2,
					"name": "siagrob1.view.produtos.Main"
				},
				"tabelaCusto": {
					"id": "tabelaCusto",
          "level": 2,
					"name": "siagrob1.view.tabelaCusto.Main"
				},
				"tabelaCustoNew": {
					"id": "tabelaCustoNew",
          "level": 2,
					"name": "siagrob1.view.tabelaCusto.Add"
				},
				"tabelaCustoEdit": {
					"id": "tabelaCustoEdit",
          "level": 2,
					"name": "siagrob1.view.tabelaCusto.Edit"
				},
        "armazens": {
					"id": "armazens",
          "level": 2,
					"name": "siagrob1.view.armazem.Main"
				},
        "armazensNew": {
					"id": "armazensNew",
          "level": 2,
					"name": "siagrob1.view.armazem.Add"
				},
        "armazensEdit": {
					"id": "armazensEdit",
          "level": 2,
					"name": "siagrob1.view.armazem.Edit"
				},
        "lotesArmazenagem": {
					"id": "lotesArmazenagem",
          "level": 2,
					"name": "siagrob1.view.loteArmazenagem.Main"
				},"lotesArmazenagemNew": {
					"id": "lotesArmazenagemNew",
          "level": 2,
					"name": "siagrob1.view.loteArmazenagem.Add"
				},"lotesArmazenagemEdit": {
					"id": "lotesArmazenagemEdit",
          "level": 2,
					"name": "siagrob1.view.loteArmazenagem.Edit"
				},
        "safras": {
					"id": "safras",
          "level": 2,
					"name": "siagrob1.view.safra.Main"
				},"safrasNew": {
					"id": "safrasNew",
          "level": 2,
					"name": "siagrob1.view.safra.Add"
				},"safrasEdit": {
					"id": "safrasEdit",
          "level": 2,
					"name": "siagrob1.view.safra.Edit"
				},
        "motoristas": {
					"id": "motoristas",
          "level": 2,
					"name": "siagrob1.view.motorista.Main"
				},"motoristasNew": {
					"id": "motoristasNew",
          "level": 2,
					"name": "siagrob1.view.motorista.Add"
				},"motoristasEdit": {
					"id": "motoristasEdit",
          "level": 2,
					"name": "siagrob1.view.motorista.Edit"
				},
        "veiculos": {
					"id": "veiculos",
          "level": 2,
					"name": "siagrob1.view.veiculo.Main"
				},"veiculosNew": {
					"id": "veiculosNew",
          "level": 2,
					"name": "siagrob1.view.veiculo.Add"
				},"veiculosEdit": {
					"id": "veiculosEdit",
          "level": 2,
					"name": "siagrob1.view.veiculo.Edit"
				}
			}
		}
	}
}
