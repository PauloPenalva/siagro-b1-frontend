{
	"_version": "1.21.0",

	"sap.app": {
		"id": "siagrob1",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "${version}"
		},
		"sourceTemplate": {
			"id": "generator-ui5-ts-app",
			"version": "1.1.0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/",
				"type": "OData",
        "settings": {
				  "odataVersion": "4.0"
				}
			}
		}
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},

	"sap.ui5": {
		"rootView": {
			"viewName": "siagrob1.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.141.0",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "siagrob1.i18n.i18n",
					"supportedLocales": ["en", "de", "pt-BR", ""],
					"fallbackLocale": "pt-BR",
					"async": true
				}
			},
			"": {
				"type": "sap.ui.model.odata.v4.ODataModel",
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"synchronizationMode": "None",
					"autoExpandSelect": true,
					"earlyRequests": true,
					"updateGroupId" : "UpdateGroup",
					"groupId": "$auto",
					"httpHeaders": { }
				}
			},
			"ui": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {}
			},
      "viewModel": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {}
			},
      "sessionModel": {
        "type": "sap.ui.model.json.JSONModel",
				"settings": {}
      }
   	},

