		"rootView": {
			"viewName": "siagrob1.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.141.0",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "siagrob1.i18n.i18n",
					"supportedLocales": ["en", "de", "pt-BR", ""],
					"fallbackLocale": "pt-BR",
					"async": true
				}
			},
			"": {
				"type": "sap.ui.model.odata.v4.ODataModel",
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"synchronizationMode": "None",
					"autoExpandSelect": true,
					"earlyRequests": true,
					"updateGroupId" : "UpdateGroup",
					"groupId": "$auto",
					"httpHeaders": { }
				}
			},
			"ui": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {}
			},
      "viewModel": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {}
			},
      "sessionModel": {
        "type": "sap.ui.model.json.JSONModel",
				"settings": {}
      }
   	},

