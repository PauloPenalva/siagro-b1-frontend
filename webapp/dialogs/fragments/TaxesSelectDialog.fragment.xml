<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>

<TableSelectDialog 
  class="sapUiPopupWithPadding sapUiSizeCompact"
  growing="true"
  growingThreshold="20"
  items="{
    path: '/Taxes',
    sorter: {
      path: 'Code', 
      descending: false
    }
  }"
  rememberSelections="true"
  title="Impostos"
>
<columns>
  <Column>
    <header>
      <Text text="Codigo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Nome" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Aliquota %" />
    </header>
  </Column>
</columns>
<ColumnListItem >
  <cells>
    <Text text="{Code}" />
    <Text text="{Name}" />   
    <Text text="{
      path: 'Rate',
      type: 'sap.ui.model.type.Float',
      formatOptions: {
          decimals: 4,
          decimalSeparator: ',',
          groupingEnabled: true,
          groupingSeparator: '.'
      } 
    }" />   
  </cells>
</ColumnListItem>
</TableSelectDialog>
</core:FragmentDefinition>
