<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>

<TableSelectDialog 
  class=" sapUiSizeCompact"
  growing="true"
  growingThreshold="20"
  items="{
    path: '/BusinessPartners',
    sorter: {
      path: 'CardName', 
      descending: false
    }
  }"
  rememberSelections="true"
  title="Cli/For"
>
<columns>
  <Column>
    <header>
      <Text text="Codigo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Tipo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Nome" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Cnpj/Cpf" />
    </header>
  </Column>
</columns>
<ColumnListItem >
  <cells>
    <Text text="{CardCode}" />
    <Text text="{
      parts: ['CardType'],
      formatter: '.formatter.formatCardType'
    }" />
    <Text text="{CardName}" />
     <Text text="{
      parts: ['TaxId'],
      formatter: '.formatter.formatCnpj'
    }" />
  </cells>
</ColumnListItem>
</TableSelectDialog>
</core:FragmentDefinition>
