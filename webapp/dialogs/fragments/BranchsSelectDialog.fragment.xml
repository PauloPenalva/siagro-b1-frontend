<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <TableSelectDialog
        class=" sapUiSizeCompact"
        growing="true"
        growingThreshold="20"
        items="{
          path: '/Branchs',
          sorter: {
            path: 'Code', 
            descending: false
          }
        }"
        rememberSelections="true"
        title="Filiais"
    >
        <columns>
            <Column>
                <header>
                    <Text text="Codigo" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Nome" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Nome Curto" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="CNPJ" />
                </header>
            </Column>
        </columns>
        <ColumnListItem>
            <cells>
                <Text text="{Code}" />
                <Text text="{BranchName}" />
                <Text text="{ShortName}" />
                <Text text="{TaxId}" />
            </cells>
        </ColumnListItem>
    </TableSelectDialog>
</core:FragmentDefinition>
