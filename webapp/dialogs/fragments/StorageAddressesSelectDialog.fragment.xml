<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <TableSelectDialog
        id="storageAddressesSelectTable"
        class=" sapUiSizeCompact"
        growing="true"
        growingThreshold="20"
        items="{
          path: '/StorageAddresses',
          sorter: {
            path: 'Code', 
            descending: false
          }
        }"
        rememberSelections="true"
        title="Lotes de Armazenagem"
    >
        <columns>
            <Column>
                <header>
                    <Text text="Codigo" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Descrição" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Cliente" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Produto" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Armazem" />
                </header>
            </Column>
            <Column hAlign="End">
                <header>
                    <Text text="Saldo" />
                </header>
            </Column>
        </columns>
        <ColumnListItem>
            <cells>
                <Text text="{Code}" />
                <Text text="{Description}" />
                <Text text="({CardCode}) {CardName}" />
                <Text text="({ItemCode}) {ItemName}" />
                <Text text="{WarehouseCode}" />
                <ObjectNumber number="{Balance}" unit="KG" />
            </cells>
        </ColumnListItem>
    </TableSelectDialog>
</core:FragmentDefinition>
