<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>

<TableSelectDialog 
  class=" sapUiSizeCompact"
  growing="true"
  growingThreshold="20"
  items="{
    path: '/BusinessPartners',
    sorter: {
      path: 'CardName', 
      descending: false
    },
    filters:[
      { path: 'CardType', operator: 'EQ', value1: 'S'}
    ],
    parameters: {
      $expand: 'Addresses($filter=AdresType eq \'S\')'
    }
  }"
  rememberSelections="true"
  title="Fornecedores"
>
<columns>
  <Column>
    <header>
      <Text />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Codigo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Razão Social" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Nome Fantasia" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Cnpj/Cpf" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Municipio" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Uf" />
    </header>
  </Column>
</columns>
<ColumnListItem >
  <cells>
    <core:Icon tooltip="{Notes}" src="sap-icon://information" noTabStop="true"/>
    <Text text="{CardCode}" />
    <Text text="{CardName}" />
    <Text text="{CardFName}" />
    <Text text="{
      parts: ['TaxId'],
      formatter: '.formatter.formatCnpj'
    }" />
    <Text text="{Addresses/0/City}" />
    <Text text="{Addresses/0/State}" />
  </cells>
</ColumnListItem>
</TableSelectDialog>
</core:FragmentDefinition>
