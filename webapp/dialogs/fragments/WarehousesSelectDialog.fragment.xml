<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>

<TableSelectDialog 
  class=" sapUiSizeCompact"
  growing="true"
  growingThreshold="20"
  items="{
    path: '/Warehouses',
    sorter: {
      path: 'Name', 
      descending: false
    }
  }"
  rememberSelections="true"
  title="Armazéns"
>
<columns>
  <Column>
    <header>
      <Text text="" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Codigo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Razão Social" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Nome Fantasia" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="CNPJ" />
    </header>
  </Column>
   <Column>
    <header>
      <Text text="Municipio" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Uf" />
    </header>
  </Column>
</columns>
<ColumnListItem >
  <cells>
    <core:Icon tooltip="{Notes}" src="sap-icon://information" noTabStop="true"/>
    <Text text="{Code}" />
    <Text text="{Name}" />
    <Text text="{FName}" />
    <Text text="{
      path: 'TaxId',
      targetType: 'any',
      formatter: '.formatter.formatCnpj'
    }" />
    <Text text="{City}" />
    <Text text="{State}" />
  </cells>
</ColumnListItem>
</TableSelectDialog>
</core:FragmentDefinition>
