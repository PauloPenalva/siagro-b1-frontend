<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
>

<TableSelectDialog 
  class=" sapUiSizeCompact"
  growing="true"
  growingThreshold="20"
  items="{
    path: '/Items',
    sorter: {
      path: 'ItemName', 
      descending: false
    }
  }"
  rememberSelections="true"
  title="Produtos"
>
<columns>
  <Column>
    <header>
      <Text text="Codigo" />
    </header>
  </Column>
  <Column>
    <header>
      <Text text="Nome" />
    </header>
  </Column>
</columns>
<ColumnListItem >
  <cells>
    <Text text="{ItemCode}" />
    <Text text="{ItemName}" />
  </cells>
</ColumnListItem>
</TableSelectDialog>
</core:FragmentDefinition>
