<core:FragmentDefinition
   	xmlns="sap.tnt" 
    xmlns:core="sap.ui.core" >
    <NavigationListItem 
        text="{menu>title}" 
        icon="{menu>icon}" 
        enabled="{menu>enabled}" 
        expanded="{menu>expanded}" 
        items="{
            path: 'menu>items', 
            templateShareable:true
        }"
        key="{menu>key}">
        <NavigationListItem text="{menu>title}" key="{menu>key}" enabled="{menu>enabled}" />
    </NavigationListItem>
</core:FragmentDefinition>