<core:FragmentDefinition
   	xmlns="sap.tnt" 
    xmlns:core="sap.ui.core" >
    <SideNavigation 
        xmlns="sap.tnt" 
        xmlns:core="sap.ui.core" 
        selectedKey="{menu>/selectedKey}"
        visible="{sessionModel>/logged}"  
        itemSelect=".onItemSelect">
        <NavigationList items="{path: 'menu>/navigation'}">
            <core:Fragment fragmentName="siagrob1.fragments.SideMenuList" type="XML" />
        </NavigationList>
        <fixedItem>
            <NavigationList items="{path: 'menu>/fixedNavigation'}">
                <core:Fragment fragmentName="siagrob1.fragments.SideMenuList" type="XML" />
            </NavigationList>
        </fixedItem>
    </SideNavigation>
</core:FragmentDefinition>
