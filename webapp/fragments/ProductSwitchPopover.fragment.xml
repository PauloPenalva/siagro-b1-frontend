<core:FragmentDefinition xmlns="sap.m" xmlns:f="sap.f" xmlns:core="sap.ui.core">
	<ResponsivePopover placement="Bottom" showHeader="false">
		<f:ProductSwitch change="fnChange"
			items="{
				path: 'productSwitch>/items'
			}">
			<f:items>
				<f:ProductSwitchItem 
          src="{productSwitch>src}" 
          title="{productSwitch>title}" 
          subTitle="{productSwitch>subTitle}" 
          targetSrc="{productSwitch>targetSrc}" 
          target="{productSwitch>target}"/>
			</f:items>
		</f:ProductSwitch>
	</ResponsivePopover>
</core:FragmentDefinition>
